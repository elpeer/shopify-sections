{% doc %}
  @prompt
    gallery with option of grid or slider and allow mix images + videos MP4 with auto play without sound. if its grid need option to set if all images/videos have the same height or its auto grid, also option to set how mauch images or videos will show up in each row at mobile and desktop and after how much rows we give button of show more that reval the other media files and puss everything down. if its slider we need option to set the max height of the slider and all media will fit the width  and also add. need to allow option to set the peddign between the image/videos also allow none padding 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-gallery-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-media-gallery-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-media-gallery-grid-{{ ai_gen_id }} {
    display: grid;
    {% if block.settings.gap_size == 'none' %}
      gap: 0;
    {% else %}
      gap: {{ block.settings.gap_size }}px;
    {% endif %}
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  }

  {% if block.settings.grid_height_mode == 'same' %}
    .ai-media-gallery-grid-{{ ai_gen_id }} .ai-media-item-{{ ai_gen_id }} {
      height: {{ block.settings.grid_item_height }}px;
    }
  {% endif %}

  .ai-media-gallery-slider-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    max-height: {{ block.settings.slider_max_height }}px;
  }

  .ai-media-gallery-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.4s ease;
    {% if block.settings.gap_size == 'none' %}
      gap: 0;
    {% else %}
      gap: {{ block.settings.gap_size }}px;
    {% endif %}
  }

  .ai-media-gallery-slider-track-{{ ai_gen_id }} .ai-media-item-{{ ai_gen_id }} {
    flex: 0 0 100%;
    max-width: 100%;
  }

  .ai-media-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.media_bg_color }};
  }

  {% if block.settings.grid_height_mode == 'auto' %}
    .ai-media-item-{{ ai_gen_id }} {
      aspect-ratio: 16 / 9;
    }
  {% endif %}

  .ai-media-item-{{ ai_gen_id }} img,
  .ai-media-item-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-media-gallery-hidden-{{ ai_gen_id }} {
    display: none;
  }

  .ai-media-gallery-show-more-{{ ai_gen_id }} {
    margin-top: 20px;
    text-align: center;
  }

  .ai-media-gallery-show-more-btn-{{ ai_gen_id }} {
    padding: 12px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-media-gallery-show-more-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-media-gallery-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  .ai-media-gallery-slider-nav-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-media-gallery-slider-nav-{{ ai_gen_id }}--prev {
    left: 10px;
  }

  .ai-media-gallery-slider-nav-{{ ai_gen_id }}--next {
    right: 10px;
  }

  .ai-media-gallery-slider-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-media-gallery-slider-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 15px;
  }

  .ai-media-gallery-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .ai-media-gallery-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-media-gallery-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    background-color: #f4f4f4;
    border-radius: 8px;
  }

  .ai-media-gallery-empty-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin: 0 auto 15px;
    opacity: 0.3;
  }

  .ai-media-gallery-empty-text-{{ ai_gen_id }} {
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-media-gallery-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    {% if block.settings.grid_height_mode == 'same' %}
      .ai-media-gallery-grid-{{ ai_gen_id }} .ai-media-item-{{ ai_gen_id }} {
        height: {{ block.settings.grid_item_height | times: 0.7 }}px;
      }
    {% endif %}
  }
{% endstyle %}

<media-gallery-{{ ai_gen_id }} class="ai-media-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-media-gallery-container-{{ ai_gen_id }}">
    {% liquid
      assign total_media = 0
      for i in (1..20)
        assign image_key = 'media_' | append: i | append: '_image'
        assign video_key = 'media_' | append: i | append: '_video'
        assign image = block.settings[image_key]
        assign video = block.settings[video_key]
        if image != blank or video != blank
          assign total_media = total_media | plus: 1
        endif
      endfor
    %}

    {% if total_media == 0 %}
      <div class="ai-media-gallery-empty-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-media-gallery-empty-text-{{ ai_gen_id }}">
          Add images or videos to your gallery
        </div>
      </div>
    {% else %}
      {% if block.settings.layout_type == 'grid' %}
        <div class="ai-media-gallery-grid-{{ ai_gen_id }}">
          {% for i in (1..20) %}
            {% liquid
              assign image_key = 'media_' | append: i | append: '_image'
              assign video_key = 'media_' | append: i | append: '_video'
              assign image = block.settings[image_key]
              assign video = block.settings[video_key]
            %}

            {% if image != blank or video != blank %}
              {% liquid
                assign items_per_row_desktop = block.settings.columns_desktop
                assign items_per_row_mobile = block.settings.columns_mobile
                assign rows_before_show_more = block.settings.rows_before_show_more
                assign total_items_before_show_more = items_per_row_desktop | times: rows_before_show_more
                assign is_hidden = false
                if forloop.index > total_items_before_show_more
                  assign is_hidden = true
                endif
              %}

              <div class="ai-media-item-{{ ai_gen_id }} {% if is_hidden %}ai-media-gallery-hidden-{{ ai_gen_id }}{% endif %}" data-media-index="{{ forloop.index }}">
                {% if video != blank %}
                  <video autoplay muted loop playsinline>
                    <source src="{{ video }}" type="video/mp4">
                  </video>
                {% elsif image != blank %}
                  <img
                    src="{{ image | image_url: width: 1200 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                  >
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if total_media > total_items_before_show_more %}
          <div class="ai-media-gallery-show-more-{{ ai_gen_id }}">
            <button class="ai-media-gallery-show-more-btn-{{ ai_gen_id }}" data-show-more>
              {{ block.settings.show_more_text }}
            </button>
          </div>
        {% endif %}
      {% else %}
        <div class="ai-media-gallery-slider-{{ ai_gen_id }}">
          <div class="ai-media-gallery-slider-track-{{ ai_gen_id }}">
            {% for i in (1..20) %}
              {% liquid
                assign image_key = 'media_' | append: i | append: '_image'
                assign video_key = 'media_' | append: i | append: '_video'
                assign image = block.settings[image_key]
                assign video = block.settings[video_key]
              %}

              {% if image != blank or video != blank %}
                <div class="ai-media-item-{{ ai_gen_id }}">
                  {% if video != blank %}
                    <video autoplay muted loop playsinline>
                      <source src="{{ video }}" type="video/mp4">
                    </video>
                  {% elsif image != blank %}
                    <img
                      src="{{ image | image_url: width: 1200 }}"
                      alt="{{ image.alt | escape }}"
                      loading="lazy"
                      width="{{ image.width }}"
                      height="{{ image.height }}"
                    >
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>

          {% if total_media > 1 %}
            <button class="ai-media-gallery-slider-nav-{{ ai_gen_id }} ai-media-gallery-slider-nav-{{ ai_gen_id }}--prev" data-slider-prev>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button class="ai-media-gallery-slider-nav-{{ ai_gen_id }} ai-media-gallery-slider-nav-{{ ai_gen_id }}--next" data-slider-next>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>

            <div class="ai-media-gallery-slider-dots-{{ ai_gen_id }}">
              {% for i in (1..total_media) %}
                <button class="ai-media-gallery-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slider-dot="{{ forloop.index0 }}"></button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</media-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        {% if block.settings.layout_type == 'slider' %}
          this.isSlider = true;
        {% else %}
          this.isSlider = false;
        {% endif %}
      }

      connectedCallback() {
        if (this.isSlider) {
          this.initSlider();
        } else {
          this.initGrid();
        }
      }

      initGrid() {
        const showMoreBtn = this.querySelector('[data-show-more]');
        if (showMoreBtn) {
          showMoreBtn.addEventListener('click', () => {
            const hiddenItems = this.querySelectorAll('.ai-media-gallery-hidden-{{ ai_gen_id }}');
            hiddenItems.forEach(item => {
              item.classList.remove('ai-media-gallery-hidden-{{ ai_gen_id }}');
            });
            showMoreBtn.parentElement.style.display = 'none';
          });
        }
      }

      initSlider() {
        this.track = this.querySelector('.ai-media-gallery-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-media-item-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('[data-slider-prev]');
        this.nextBtn = this.querySelector('[data-slider-next]');
        this.dots = this.querySelectorAll('[data-slider-dot]');

        if (!this.track || this.slides.length === 0) return;

        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach(dot => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.getAttribute('data-slider-dot'));
            this.goToSlide(index);
          });
        });

        this.updateSlider();
      }

      prevSlide() {
        this.currentSlide = this.currentSlide === 0 ? this.slides.length - 1 : this.currentSlide - 1;
        this.updateSlider();
      }

      nextSlide() {
        this.currentSlide = this.currentSlide === this.slides.length - 1 ? 0 : this.currentSlide + 1;
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      updateSlider() {
        if (!this.track) return;
        
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('media-gallery-{{ ai_gen_id }}', MediaGallery{{ ai_gen_id }});
  })();
</script>

