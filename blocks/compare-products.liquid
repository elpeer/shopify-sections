{% doc %}
  @prompt
    Compare Products – 3-product comparison table
    Displays a feature-by-feature comparison of 3 products side by side.
    Desktop: 3 columns visible. Mobile: horizontal scroll (swipe).
    Each product has its own image, name, badge, and per-row feature values.
    All content is editable via Shopify customizer settings.
{% enddoc %}

{% assign cp_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ── Section wrapper ── */
  .cp-section-{{ cp_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    {% if block.settings.background_gradient != blank %}
      background: {{ block.settings.background_gradient }};
    {% else %}
      background: {{ block.settings.bg_color }};
    {% endif %}
    position: relative;
    overflow: hidden;
  }

  .cp-section-{{ cp_id }} .cp-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .cp-section-{{ cp_id }} .cp-inner {
    position: relative;
    z-index: 1;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── Heading ── */
  .cp-section-{{ cp_id }} .cp-heading {
    text-align: center;
    margin-bottom: 32px;
  }

  .cp-section-{{ cp_id }} .cp-heading__title {
    color: {{ block.settings.heading_color }};
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 8px;
  }

  .cp-section-{{ cp_id }} .cp-heading__sub {
    color: {{ block.settings.muted_color }};
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Card container ── */
  .cp-section-{{ cp_id }} .cp-card {
    background: rgba(255, 255, 255, {{ block.settings.card_opacity }});
    border-radius: {{ block.settings.card_radius }}px;
    border: 1px solid {{ block.settings.card_border_color }};
    {% if block.settings.enable_glass %}
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    {% endif %}
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  /* ── Table grid ── */
  .cp-section-{{ cp_id }} .cp-table {
    display: grid;
    grid-template-columns: minmax(120px, 1.2fr) repeat(3, 1fr);
    width: 100%;
  }

  /* ── Header cells ── */
  .cp-section-{{ cp_id }} .cp-hdr {
    padding: 20px 16px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .cp-section-{{ cp_id }} .cp-hdr--feature {
    align-items: flex-start;
    justify-content: flex-end;
    text-align: left;
  }

  .cp-section-{{ cp_id }} .cp-hdr__feature-label {
    color: {{ block.settings.muted_color }};
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .cp-section-{{ cp_id }} .cp-hdr__img {
    width: {{ block.settings.product_image_size }}px;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
  }

  .cp-section-{{ cp_id }} .cp-hdr__name {
    color: {{ block.settings.heading_color }};
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .cp-section-{{ cp_id }} .cp-hdr__badge {
    display: inline-block;
    background: {{ block.settings.accent_color }};
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 20px;
    line-height: 1.4;
  }

  /* ── Highlighted column ── */
  .cp-section-{{ cp_id }} .cp-hdr--highlight {
    background: rgba(255, 255, 255, 0.05);
  }

  .cp-section-{{ cp_id }} .cp-cell--highlight {
    background: rgba(255, 255, 255, 0.03);
  }

  /* ── Data cells ── */
  .cp-section-{{ cp_id }} .cp-row-label {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    color: {{ block.settings.muted_color }};
    font-size: 13px;
    font-weight: 600;
    line-height: 1.3;
    {% if block.settings.show_dividers %}
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    {% endif %}
  }

  .cp-section-{{ cp_id }} .cp-cell {
    padding: 14px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    {% if block.settings.show_dividers %}
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    {% endif %}
  }

  /* ── Special advantage row ── */
  .cp-section-{{ cp_id }} .cp-advantage {
    padding: 14px 12px;
    text-align: center;
    color: {{ block.settings.accent_color }};
    font-size: 12px;
    font-weight: 600;
    font-style: italic;
    line-height: 1.4;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cp-section-{{ cp_id }} .cp-advantage--label {
    color: {{ block.settings.muted_color }};
    text-align: left;
    font-style: normal;
  }

  /* ── Mobile: horizontal scroll ── */
  @media screen and (max-width: 749px) {
    .cp-section-{{ cp_id }} {
      padding: 32px 16px;
    }

    .cp-section-{{ cp_id }} .cp-heading__title {
      font-size: 24px;
    }

    .cp-section-{{ cp_id }} .cp-heading__sub {
      font-size: 14px;
    }

    .cp-section-{{ cp_id }} .cp-card {
      overflow: visible;
    }

    .cp-section-{{ cp_id }} .cp-scroll-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin: 0 -16px;
      padding: 0 16px;
    }

    .cp-section-{{ cp_id }} .cp-scroll-wrap::-webkit-scrollbar {
      display: none;
    }

    .cp-section-{{ cp_id }} .cp-table {
      grid-template-columns: minmax(100px, 120px) repeat(3, minmax(130px, 1fr));
      min-width: 560px;
    }

    .cp-section-{{ cp_id }} .cp-hdr {
      padding: 14px 10px 12px;
    }

    .cp-section-{{ cp_id }} .cp-hdr__img {
      width: 50px;
    }

    .cp-section-{{ cp_id }} .cp-hdr__name {
      font-size: 12px;
    }

    .cp-section-{{ cp_id }} .cp-hdr__badge {
      font-size: 8px;
      padding: 2px 8px;
    }

    .cp-section-{{ cp_id }} .cp-row-label {
      font-size: 12px;
      padding: 10px 10px;
    }

    .cp-section-{{ cp_id }} .cp-cell {
      font-size: 12px;
      padding: 10px 8px;
    }

    .cp-section-{{ cp_id }} .cp-advantage {
      font-size: 11px;
      padding: 10px 8px;
    }
  }

  /* ── Scroll hint indicator (mobile) ── */
  .cp-section-{{ cp_id }} .cp-scroll-hint {
    display: none;
    text-align: center;
    padding: 8px 0 0;
    color: {{ block.settings.muted_color }};
    font-size: 12px;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .cp-section-{{ cp_id }} .cp-scroll-hint {
      display: block;
    }
  }
{% endstyle %}

<div class="cp-section-{{ cp_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image != blank %}
    <img
      class="cp-bg-image"
      src="{{ block.settings.background_image | image_url: width: 1920 }}"
      alt=""
      loading="lazy"
      width="1920"
      height="{{ 1920 | divided_by: block.settings.background_image.aspect_ratio | round }}"
    >
  {% endif %}

  <div class="cp-inner">
    {%- if block.settings.heading != blank or block.settings.subheading != blank -%}
      <div class="cp-heading">
        {% if block.settings.heading != blank %}
          <h2 class="cp-heading__title">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="cp-heading__sub">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {%- endif -%}

    <div class="cp-card">
      <div class="cp-scroll-wrap">
        <div class="cp-table">

          {%- comment -%} ── Header row ── {%- endcomment -%}
          <div class="cp-hdr cp-hdr--feature">
            <p class="cp-hdr__feature-label">{{ block.settings.feature_column_label }}</p>
          </div>

          {% for n in (1..3) %}
            {%- liquid
              assign img_key = 'product_' | append: n | append: '_image'
              assign name_key = 'product_' | append: n | append: '_name'
              assign badge_key = 'product_' | append: n | append: '_badge'
              assign hl_key = 'product_' | append: n | append: '_highlight'

              assign p_img = block.settings[img_key]
              assign p_name = block.settings[name_key]
              assign p_badge = block.settings[badge_key]
              assign p_hl = block.settings[hl_key]
            -%}
            <div class="cp-hdr{% if p_hl %} cp-hdr--highlight{% endif %}">
              {%- if p_img != blank -%}
                {%- assign img_w2x = block.settings.product_image_size | times: 2 -%}
                <img
                  class="cp-hdr__img"
                  src="{{ p_img | image_url: width: img_w2x }}"
                  alt="{{ p_name | escape }}"
                  loading="lazy"
                  width="{{ block.settings.product_image_size }}"
                  height="{{ block.settings.product_image_size }}"
                >
              {%- endif -%}
              <p class="cp-hdr__name">{{ p_name }}</p>
              {% if p_badge != blank %}
                <span class="cp-hdr__badge">{{ p_badge }}</span>
              {% endif %}
            </div>
          {% endfor %}

          {%- comment -%} ── Feature rows ── {%- endcomment -%}
          {% for i in (1..8) %}
            {%- liquid
              assign label_key = 'row_' | append: i | append: '_label'
              assign val1_key = 'row_' | append: i | append: '_p1'
              assign val2_key = 'row_' | append: i | append: '_p2'
              assign val3_key = 'row_' | append: i | append: '_p3'

              assign r_label = block.settings[label_key]
              assign r_val1 = block.settings[val1_key]
              assign r_val2 = block.settings[val2_key]
              assign r_val3 = block.settings[val3_key]
            -%}

            {% if r_label != blank %}
              <div class="cp-row-label">{{ r_label }}</div>
              {% for n in (1..3) %}
                {%- liquid
                  assign val_key = 'row_' | append: i | append: '_p' | append: n
                  assign hl_key = 'product_' | append: n | append: '_highlight'
                  assign r_val = block.settings[val_key]
                  assign p_hl = block.settings[hl_key]
                -%}
                <div class="cp-cell{% if p_hl %} cp-cell--highlight{% endif %}">{{ r_val }}</div>
              {% endfor %}
            {% endif %}
          {% endfor %}

          {%- comment -%} ── Special advantage row ── {%- endcomment -%}
          {%- liquid
            assign adv1 = block.settings.product_1_advantage
            assign adv2 = block.settings.product_2_advantage
            assign adv3 = block.settings.product_3_advantage
            assign has_advantages = false
            if adv1 != blank or adv2 != blank or adv3 != blank
              assign has_advantages = true
            endif
          -%}

          {% if has_advantages %}
            <div class="cp-advantage cp-advantage--label">{{ block.settings.advantage_label }}</div>
            <div class="cp-advantage{% if block.settings.product_1_highlight %} cp-cell--highlight{% endif %}">{{ adv1 }}</div>
            <div class="cp-advantage{% if block.settings.product_2_highlight %} cp-cell--highlight{% endif %}">{{ adv2 }}</div>
            <div class="cp-advantage{% if block.settings.product_3_highlight %} cp-cell--highlight{% endif %}">{{ adv3 }}</div>
          {% endif %}

        </div>
      </div>

      <div class="cp-scroll-hint">
        ← {{ block.settings.scroll_hint_text }} →
      </div>
    </div>
  </div>
</div>

