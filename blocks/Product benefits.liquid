{% doc %}
  @prompt
    Create a section exactly like the attached reference:
    - Desktop: headline centered at top, then a 3-column layout:
      Left column: 2 benefit items (icon + title + short text)
      Center column: a main image OR video
      Right column: 2 benefit items (icon + title + short text)
      Bottom: centered CTA button (“SHOP NOW”)
    - Mobile: layout becomes like reference #2:
      Headline on top
      Center media (image/video) under headline (full width)
      Benefits become a 2-column grid (2 items per row), then CTA full width at bottom.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-benefits-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-benefits-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 40px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
  }

  .ai-benefits-layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 40px;
  }

  .ai-benefits-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .ai-benefits-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .ai-benefits-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-benefits-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-benefits-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-benefits-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-benefits-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-benefits-item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-benefits-media-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.media_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.media_border_radius }}px;
  }

  .ai-benefits-media-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-benefits-media-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-benefits-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-benefits-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-benefits-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-benefits-cta-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-benefits-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 48px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-benefits-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: 24px;
    }

    .ai-benefits-layout-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 24px;
    }

    .ai-benefits-column-{{ ai_gen_id }} {
      order: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .ai-benefits-media-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-benefits-item-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-benefits-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-benefits-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-benefits-item-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-benefits-button-{{ ai_gen_id }} {
      width: 100%;
      padding: 14px 32px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-benefits-{{ ai_gen_id }} class="ai-benefits-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-benefits-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-benefits-layout-{{ ai_gen_id }}">
      <div class="ai-benefits-column-{{ ai_gen_id }} ai-benefits-column-left-{{ ai_gen_id }}">
        {% for i in (1..2) %}
          {% liquid
            assign icon_key = 'benefit_' | append: i | append: '_icon'
            assign title_key = 'benefit_' | append: i | append: '_title'
            assign text_key = 'benefit_' | append: i | append: '_text'
            
            assign icon = block.settings[icon_key]
            assign title = block.settings[title_key]
            assign text = block.settings[text_key]
          %}
          
          <div class="ai-benefits-item-{{ ai_gen_id }}">
            <div class="ai-benefits-icon-{{ ai_gen_id }}">
              {% if icon %}
                <img src="{{ icon | image_url: width: 200 }}" alt="{{ title | escape }}" loading="lazy" width="200" height="200">
              {% else %}
                <div class="ai-benefits-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if title != blank %}
              <h3 class="ai-benefits-item-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}
            {% if text != blank %}
              <p class="ai-benefits-item-text-{{ ai_gen_id }}">{{ text }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <div class="ai-benefits-media-{{ ai_gen_id }}">
        {% if block.settings.video_url != blank %}
          <video autoplay muted loop playsinline>
            <source src="{{ block.settings.video_url }}" type="video/mp4">
          </video>
        {% elsif block.settings.media_image %}
          <img src="{{ block.settings.media_image | image_url: width: 1000 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="{{ block.settings.media_image.width }}" height="{{ block.settings.media_image.height }}">
        {% else %}
          <div class="ai-benefits-media-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
            <div class="ai-benefits-empty-state-{{ ai_gen_id }}">
              Add an image or video
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-benefits-column-{{ ai_gen_id }} ai-benefits-column-right-{{ ai_gen_id }}">
        {% for i in (3..4) %}
          {% liquid
            assign icon_key = 'benefit_' | append: i | append: '_icon'
            assign title_key = 'benefit_' | append: i | append: '_title'
            assign text_key = 'benefit_' | append: i | append: '_text'
            
            assign icon = block.settings[icon_key]
            assign title = block.settings[title_key]
            assign text = block.settings[text_key]
          %}
          
          <div class="ai-benefits-item-{{ ai_gen_id }}">
            <div class="ai-benefits-icon-{{ ai_gen_id }}">
              {% if icon %}
                <img src="{{ icon | image_url: width: 200 }}" alt="{{ title | escape }}" loading="lazy" width="200" height="200">
              {% else %}
                <div class="ai-benefits-icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if title != blank %}
              <h3 class="ai-benefits-item-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}
            {% if text != blank %}
              <p class="ai-benefits-item-text-{{ ai_gen_id }}">{{ text }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    {% if block.settings.button_text != blank %}
      <div class="ai-benefits-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-benefits-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</product-benefits-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductBenefits{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initVideo();
      }

      initVideo() {
        const video = this.querySelector('video');
        if (video) {
          video.play().catch(function() {});
        }
      }
    }

    customElements.define('product-benefits-{{ ai_gen_id }}', ProductBenefits{{ ai_gen_id }});
  })();
</script>

