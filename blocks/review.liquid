{%- comment -%}--- MEDIA ---{%- endcomment -%}
<div class="rc-media-wrap">
  {%- case block.settings.media_type -%}

    {%- when 'image' -%}
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          alt="{{ block.settings.image_alt | escape }}"
          loading="lazy"
          width="800"
          height="{{ 800 | divided_by: block.settings.image.aspect_ratio | round }}"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

    {%- when 'video_upload' -%}
      <video
        playsinline
        {% if block.settings.video_autoplay %}autoplay{% endif %}
        {% if block.settings.video_loop %}loop{% endif %}
        {% if block.settings.video_muted %}muted{% endif %}
        {% if block.settings.image != blank %}poster="{{ block.settings.image | image_url: width: 800 }}"{% endif %}
        data-fallback-img="{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 800 }}{% endif %}"
      >
        {%- for source in block.settings.video_file.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
      {%- if block.settings.show_play_icon_overlay -%}
        <div class="rc-play-overlay" aria-label="{{ 'accessibility.play' | t | default: 'Play video' }}" role="button" tabindex="0">
          <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
        </div>
      {%- endif -%}

    {%- when 'external_video' -%}
      {%- assign video_url = block.settings.external_video_url -%}
      {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
        {%- if video_url contains 'youtu.be' -%}
          {%- assign yt_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}
        {%- else -%}
          {%- assign yt_id = video_url | split: 'v=' | last | split: '&' | first -%}
        {%- endif -%}
        <iframe
          src="https://www.youtube.com/embed/{{ yt_id }}?{% if block.settings.video_autoplay %}autoplay=1&{% endif %}{% if block.settings.video_muted %}mute=1&{% endif %}{% if block.settings.video_loop %}loop=1&playlist={{ yt_id }}&{% endif %}playsinline=1&rel=0"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title="{{ block.settings.reviewer_name | default: 'Review' }} video"
        ></iframe>
      {%- elsif video_url contains 'vimeo.com' -%}
        {%- assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first -%}
        <iframe
          src="https://player.vimeo.com/video/{{ vimeo_id }}?{% if block.settings.video_autoplay %}autoplay=1&{% endif %}{% if block.settings.video_muted %}muted=1&{% endif %}{% if block.settings.video_loop %}loop=1&{% endif %}playsinline=1"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title="{{ block.settings.reviewer_name | default: 'Review' }} video"
        ></iframe>
      {%- endif -%}
      {%- if block.settings.show_play_icon_overlay -%}
        <div class="rc-play-overlay" aria-label="{{ 'accessibility.play' | t | default: 'Play video' }}" role="button" tabindex="0">
          <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
        </div>
      {%- endif -%}

  {%- endcase -%}
</div>

{%- comment -%}--- CARD BODY ---{%- endcomment -%}
<div class="rc-body">
  {%- comment -%}Stars{%- endcomment -%}
  {%- assign rating = block.settings.rating -%}
  {%- assign block_uid = section.id | append: '-' | append: block.id -%}
  <div class="rc-stars" role="img" aria-label="{{ rating }} out of 5 stars">
    {%- for i in (1..5) -%}
      {%- assign full_threshold = i | minus: 0 -%}
      {%- assign half_threshold = i | minus: 0.5 -%}
      {%- if rating >= full_threshold -%}
        <svg viewBox="0 0 24 24"><path class="rc-star-full" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {%- elsif rating >= half_threshold -%}
        <svg viewBox="0 0 24 24">
          <defs><linearGradient id="half-{{ block_uid }}-{{ i }}"><stop offset="50%" stop-color="var(--rc-star-color)"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs>
          <path fill="url(#half-{{ block_uid }}-{{ i }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      {%- else -%}
        <svg viewBox="0 0 24 24"><path class="rc-star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%}Reviewer{%- endcomment -%}
  <div class="rc-reviewer">
    <span class="rc-reviewer-name">{{ block.settings.reviewer_name }}</span>
    {%- if block.settings.reviewer_age != blank -%}
      <span class="rc-reviewer-age">{{ block.settings.reviewer_age }}</span>
    {%- endif -%}
    {%- if block.settings.verified -%}
      <span class="rc-verified">
        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
        {{ 'customer.reviews.verified_buyer' | t | default: 'Verified Buyer' }}
      </span>
    {%- endif -%}
  </div>

  {%- comment -%}Review text{%- endcomment -%}
  {%- if block.settings.review_text != blank -%}
    <div
      class="rc-text rc-text-clamped"
      style="-webkit-line-clamp: {{ block.settings.truncate_lines }};"
      data-truncate="{{ block.settings.truncate_lines }}"
    >
      {{ block.settings.review_text }}
    </div>
    {%- if block.settings.show_read_more -%}
      <button class="rc-read-more" data-expanded="false">
        {{ 'customer.reviews.read_more' | t | default: 'Read more' }}
      </button>
    {%- endif -%}
  {%- endif -%}

  {%- comment -%}Purchased product{%- endcomment -%}
  {%- if block.settings.purchased_product != blank -%}
    {%- assign prod = block.settings.purchased_product -%}
    <div class="rc-product">
      {%- if prod.featured_image != blank -%}
        <img
          class="rc-product-img"
          src="{{ prod.featured_image | image_url: width: 120 }}"
          alt="{{ prod.featured_image.alt | escape }}"
          loading="lazy"
          width="56"
          height="56"
        >
      {%- endif -%}
      <div class="rc-product-info">
        <p class="rc-product-title">
          <a href="{{ prod.url }}">{{ prod.title }}</a>
        </p>
        <div class="rc-product-pricing">
          <span class="rc-product-price">{{ prod.price | money }}</span>
          {%- if block.settings.show_compare_price and prod.compare_at_price > prod.price -%}
            <span class="rc-product-compare">{{ prod.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
        {%- if block.settings.purchase_note != blank -%}
          <div class="rc-purchase-note">{{ block.settings.purchase_note }}</div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Review",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video_upload", "label": "Uploaded video" },
        { "value": "external_video", "label": "External video (YouTube/Vimeo)" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Video file (Shopify hosted)"
    },
    {
      "type": "url",
      "id": "external_video_url",
      "label": "External video URL (YouTube / Vimeo)"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_play_icon_overlay",
      "label": "Show play icon overlay",
      "default": false
    },
    {
      "type": "header",
      "content": "Review"
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "default": 5
    },
    {
      "type": "text",
      "id": "reviewer_name",
      "label": "Reviewer name",
      "default": "Jane D."
    },
    {
      "type": "text",
      "id": "reviewer_age",
      "label": "Reviewer age (optional)"
    },
    {
      "type": "checkbox",
      "id": "verified",
      "label": "Verified buyer",
      "default": true
    },
    {
      "type": "textarea",
      "id": "review_text",
      "label": "Review text",
      "default": "This product is amazing! I've been using it for a month and the results are incredible. Highly recommend to everyone."
    },
    {
      "type": "range",
      "id": "truncate_lines",
      "label": "Truncate text lines",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "Show read more button",
      "default": true
    },
    {
      "type": "header",
      "content": "Purchased product"
    },
    {
      "type": "product",
      "id": "purchased_product",
      "label": "Purchased product (optional)"
    },
    {
      "type": "text",
      "id": "purchase_note",
      "label": "Purchase note",
      "info": "e.g. \"Purchased on March 15\""
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show compare-at price",
      "default": true
    }
  ]
}
{% endschema %}
