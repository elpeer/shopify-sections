{% doc %}
  Icon Benefits + Center Media (Image/Video)
  ────────────────────────────────────────────
  Desktop: headline centered, 3-column layout (left benefits | center media | right benefits), CTA below.
  Mobile: headline, center media full-width, benefits 2-column grid, CTA full-width.
{% enddoc %}

{% assign bid = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign left_benefits = ''
  assign right_benefits = ''
  assign left_count = 0
  assign right_count = 0

  for b in block.settings
  endfor
-%}

{% style %}
  /* ── Wrapper ── */
  .ib-section-{{ bid }} {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding-top: {{ block.settings.spacing_top }}px;
    padding-bottom: {{ block.settings.spacing_bottom }}px;
  }

  .ib-container-{{ bid }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Heading ── */
  .ib-heading-{{ bid }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ib-heading-{{ bid }} h2 {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px;
  }

  .ib-heading-{{ bid }} p {
    font-size: 16px;
    opacity: 0.75;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  /* ── Desktop Grid ── */
  .ib-grid-{{ bid }} {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1fr;
    gap: 40px;
    align-items: center;
  }

  /* ── Benefit columns ── */
  .ib-col-{{ bid }} {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .ib-col-left-{{ bid }} {
    text-align: right;
  }

  .ib-col-right-{{ bid }} {
    text-align: left;
  }

  /* ── Benefit item ── */
  .ib-benefit-{{ bid }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ib-col-left-{{ bid }} .ib-benefit-{{ bid }} {
    align-items: flex-end;
  }

  .ib-col-right-{{ bid }} .ib-benefit-{{ bid }} {
    align-items: flex-start;
  }

  .ib-benefit__icon-{{ bid }} {
    width: var(--ib-icon-size, 40px);
    height: var(--ib-icon-size, 40px);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }

  .ib-benefit__icon-{{ bid }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ib-benefit__icon-{{ bid }} svg {
    width: 100%;
    height: 100%;
  }

  .ib-benefit__title-{{ bid }} {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: {{ block.settings.heading_color }};
  }

  .ib-benefit__title-bold-{{ bid }} {
    font-weight: 900;
  }

  .ib-benefit__text-{{ bid }} {
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.7;
    color: {{ block.settings.text_color }};
  }

  /* ── Center media ── */
  .ib-media-{{ bid }} {
    width: 100%;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
    {% if block.settings.media_aspect_ratio != 'auto' %}
      aspect-ratio: {{ block.settings.media_aspect_ratio }};
    {% endif %}
  }

  .ib-media-{{ bid }} img,
  .ib-media-{{ bid }} video {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.media_fit }};
    display: block;
  }

  .ib-media-{{ bid }} iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .ib-media__placeholder-{{ bid }} {
    width: 100%;
    aspect-ratio: 4/5;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.media_border_radius }}px;
    color: #999;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  /* ── CTA ── */
  .ib-cta-wrap-{{ bid }} {
    text-align: center;
    margin-top: 48px;
  }

  .ib-cta-{{ bid }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 36px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: {{ block.settings.cta_radius }}px;
    transition: opacity 0.2s;
    cursor: pointer;
  }

  .ib-cta-{{ bid }}:hover {
    opacity: 0.85;
  }

  .ib-cta-filled-{{ bid }} {
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    border: 2px solid {{ block.settings.cta_bg_color }};
  }

  .ib-cta-outline-{{ bid }} {
    background-color: transparent;
    color: {{ block.settings.cta_bg_color }};
    border: 2px solid {{ block.settings.cta_bg_color }};
  }

  .ib-cta__arrow-{{ bid }} {
    width: 16px;
    height: 16px;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .ib-heading-{{ bid }} {
      margin-bottom: 24px;
    }

    .ib-heading-{{ bid }} h2 {
      font-size: 22px;
    }

    .ib-grid-{{ bid }} {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .ib-col-left-{{ bid }},
    .ib-col-right-{{ bid }} {
      display: none;
    }

    .ib-mobile-benefits-{{ bid }} {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px 16px;
    }

    .ib-mobile-benefits-{{ bid }} .ib-benefit-{{ bid }} {
      align-items: flex-start;
      text-align: left;
    }

    .ib-media-{{ bid }} {
      order: -1;
    }

    {% if block.settings.cta_full_width_mobile %}
      .ib-cta-{{ bid }} {
        width: 100%;
      }
    {% endif %}

    .ib-cta-wrap-{{ bid }} {
      margin-top: 28px;
    }
  }

  @media (min-width: 769px) {
    .ib-mobile-benefits-{{ bid }} {
      display: none;
    }
  }
{% endstyle %}

<div class="ib-section-{{ bid }}">
  <div class="ib-container-{{ bid }}">

    {%- comment -%} ── Heading ── {%- endcomment -%}
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ib-heading-{{ bid }}">
        {% if block.settings.heading != blank %}
          <h2>{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p>{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {%- comment -%} ── Collect benefits by side ── {%- endcomment -%}
    {%- liquid
      assign left_items = ''
      assign right_items = ''
      assign all_items_sorted = ''

      for i in (1..6)
        assign title_key = 'benefit_' | append: i | append: '_title'
        assign t_val = block.settings[title_key]
        if t_val == blank
          continue
        endif

        assign side_key = 'benefit_' | append: i | append: '_side'
        assign side_val = block.settings[side_key]

        if side_val == 'left'
          if left_items != ''
            assign left_items = left_items | append: ','
          endif
          assign left_items = left_items | append: i
        else
          if right_items != ''
            assign right_items = right_items | append: ','
          endif
          assign right_items = right_items | append: i
        endif

        assign order_key = 'benefit_' | append: i | append: '_order_mobile'
        assign order_val = block.settings[order_key] | default: i
        assign entry = '' | append: order_val | append: ':' | append: i
        if all_items_sorted != ''
          assign all_items_sorted = all_items_sorted | append: ','
        endif
        assign all_items_sorted = all_items_sorted | append: entry
      endfor

      assign left_arr = left_items | split: ','
      assign right_arr = right_items | split: ','
      assign all_sorted_arr = all_items_sorted | split: ','
    -%}

    {%- comment -%} ── Desktop 3-column grid ── {%- endcomment -%}
    <div class="ib-grid-{{ bid }}">

      {%- comment -%} Left column {%- endcomment -%}
      <div class="ib-col-{{ bid }} ib-col-left-{{ bid }}">
        {% for idx_str in left_arr %}
          {%- liquid
            assign idx = idx_str | plus: 0
            assign b_icon_type = 'benefit_' | append: idx | append: '_icon_type'
            assign b_icon_image = 'benefit_' | append: idx | append: '_icon_image'
            assign b_icon_svg = 'benefit_' | append: idx | append: '_icon_svg'
            assign b_icon_size = 'benefit_' | append: idx | append: '_icon_size'
            assign b_title = 'benefit_' | append: idx | append: '_title'
            assign b_text = 'benefit_' | append: idx | append: '_text'
            assign b_emphasize = 'benefit_' | append: idx | append: '_emphasize'
          -%}
          <div class="ib-benefit-{{ bid }}">
            {% if block.settings[b_icon_type] == 'image' and block.settings[b_icon_image] != blank %}
              <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
                <img src="{{ block.settings[b_icon_image] | image_url: width: 120 }}" alt="" loading="lazy">
              </div>
            {% elsif block.settings[b_icon_type] == 'svg_upload' and block.settings[b_icon_svg] != blank %}
              <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
                {{ block.settings[b_icon_svg] }}
              </div>
            {% endif %}
            <h3 class="ib-benefit__title-{{ bid }}{% if block.settings[b_emphasize] %} ib-benefit__title-bold-{{ bid }}{% endif %}">
              {{ block.settings[b_title] }}
            </h3>
            {% if block.settings[b_text] != blank %}
              <p class="ib-benefit__text-{{ bid }}">{{ block.settings[b_text] }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Center media {%- endcomment -%}
      <div class="ib-media-{{ bid }}">
        {% if block.settings.center_media_type == 'image' %}
          {% if block.settings.center_image != blank %}
            <img
              src="{{ block.settings.center_image | image_url: width: 900 }}"
              alt="{{ block.settings.center_image_alt | escape }}"
              loading="lazy"
            >
          {% else %}
            {% if request.design_mode %}
              <div class="ib-media__placeholder-{{ bid }}">Select an image in theme settings</div>
            {% endif %}
          {% endif %}

        {% elsif block.settings.center_media_type == 'video_upload' %}
          {% if block.settings.center_video != blank %}
            {% assign poster_img = block.settings.fallback_image | default: block.settings.center_image %}
            <video
              {% if poster_img != blank %}poster="{{ poster_img | image_url: width: 900 }}"{% endif %}
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
              {% if block.settings.video_muted %}muted{% endif %}
              {% if block.settings.show_video_controls %}controls{% endif %}
              playsinline
            >
              {% for source in block.settings.center_video.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
            </video>
          {% else %}
            {% if request.design_mode %}
              <div class="ib-media__placeholder-{{ bid }}">Upload a video in theme settings</div>
            {% endif %}
          {% endif %}

        {% elsif block.settings.center_media_type == 'external_video' %}
          {% if block.settings.external_video_url != blank %}
            {%- liquid
              assign video_url = block.settings.external_video_url
              assign is_youtube = false
              assign is_vimeo = false

              if video_url contains 'youtube.com' or video_url contains 'youtu.be'
                assign is_youtube = true
              elsif video_url contains 'vimeo.com'
                assign is_vimeo = true
              endif
            -%}

            {% if is_youtube %}
              {%- liquid
                assign yt_id = ''
                if video_url contains 'v='
                  assign yt_parts = video_url | split: 'v='
                  assign yt_id = yt_parts[1] | split: '&' | first
                elsif video_url contains 'youtu.be/'
                  assign yt_parts = video_url | split: 'youtu.be/'
                  assign yt_id = yt_parts[1] | split: '?' | first
                endif
              -%}
              {% if yt_id != '' %}
                <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;">
                  <iframe
                    src="https://www.youtube.com/embed/{{ yt_id }}?autoplay={{ block.settings.video_autoplay | default: false }}&loop={{ block.settings.video_loop | default: false }}&muted={{ block.settings.video_muted | default: false }}&controls={{ block.settings.show_video_controls | default: false }}"
                    style="position:absolute;top:0;left:0;width:100%;height:100%;"
                    frameborder="0"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              {% endif %}

            {% elsif is_vimeo %}
              {%- assign vimeo_parts = video_url | split: 'vimeo.com/' -%}
              {%- assign vimeo_id = vimeo_parts[1] | split: '?' | first | split: '/' | first -%}
              {% if vimeo_id != '' %}
                <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;">
                  <iframe
                    src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay={{ block.settings.video_autoplay | default: false }}&loop={{ block.settings.video_loop | default: false }}&muted={{ block.settings.video_muted | default: false }}"
                    style="position:absolute;top:0;left:0;width:100%;height:100%;"
                    frameborder="0"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              {% endif %}
            {% endif %}
          {% else %}
            {% if request.design_mode %}
              <div class="ib-media__placeholder-{{ bid }}">Enter a YouTube or Vimeo URL in theme settings</div>
            {% endif %}
          {% endif %}

        {% else %}
          {% if request.design_mode %}
            <div class="ib-media__placeholder-{{ bid }}">Select a media type in theme settings</div>
          {% endif %}
        {% endif %}
      </div>

      {%- comment -%} Right column {%- endcomment -%}
      <div class="ib-col-{{ bid }} ib-col-right-{{ bid }}">
        {% for idx_str in right_arr %}
          {%- liquid
            assign idx = idx_str | plus: 0
            assign b_icon_type = 'benefit_' | append: idx | append: '_icon_type'
            assign b_icon_image = 'benefit_' | append: idx | append: '_icon_image'
            assign b_icon_svg = 'benefit_' | append: idx | append: '_icon_svg'
            assign b_icon_size = 'benefit_' | append: idx | append: '_icon_size'
            assign b_title = 'benefit_' | append: idx | append: '_title'
            assign b_text = 'benefit_' | append: idx | append: '_text'
            assign b_emphasize = 'benefit_' | append: idx | append: '_emphasize'
          -%}
          <div class="ib-benefit-{{ bid }}">
            {% if block.settings[b_icon_type] == 'image' and block.settings[b_icon_image] != blank %}
              <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
                <img src="{{ block.settings[b_icon_image] | image_url: width: 120 }}" alt="" loading="lazy">
              </div>
            {% elsif block.settings[b_icon_type] == 'svg_upload' and block.settings[b_icon_svg] != blank %}
              <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
                {{ block.settings[b_icon_svg] }}
              </div>
            {% endif %}
            <h3 class="ib-benefit__title-{{ bid }}{% if block.settings[b_emphasize] %} ib-benefit__title-bold-{{ bid }}{% endif %}">
              {{ block.settings[b_title] }}
            </h3>
            {% if block.settings[b_text] != blank %}
              <p class="ib-benefit__text-{{ bid }}">{{ block.settings[b_text] }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

    </div>

    {%- comment -%} ── Mobile benefits grid (hidden on desktop) ── {%- endcomment -%}
    <div class="ib-mobile-benefits-{{ bid }}">
      {% assign sorted_entries = all_sorted_arr | sort %}
      {% for entry in sorted_entries %}
        {%- liquid
          assign parts = entry | split: ':'
          assign idx = parts[1] | plus: 0
          assign b_icon_type = 'benefit_' | append: idx | append: '_icon_type'
          assign b_icon_image = 'benefit_' | append: idx | append: '_icon_image'
          assign b_icon_svg = 'benefit_' | append: idx | append: '_icon_svg'
          assign b_icon_size = 'benefit_' | append: idx | append: '_icon_size'
          assign b_title = 'benefit_' | append: idx | append: '_title'
          assign b_text = 'benefit_' | append: idx | append: '_text'
          assign b_emphasize = 'benefit_' | append: idx | append: '_emphasize'
          assign b_order = 'benefit_' | append: idx | append: '_order_mobile'
        -%}
        <div class="ib-benefit-{{ bid }}" style="order: {{ block.settings[b_order] | default: idx }};">
          {% if block.settings[b_icon_type] == 'image' and block.settings[b_icon_image] != blank %}
            <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
              <img src="{{ block.settings[b_icon_image] | image_url: width: 120 }}" alt="" loading="lazy">
            </div>
          {% elsif block.settings[b_icon_type] == 'svg_upload' and block.settings[b_icon_svg] != blank %}
            <div class="ib-benefit__icon-{{ bid }}" style="--ib-icon-size: {{ block.settings[b_icon_size] | default: 40 }}px;">
              {{ block.settings[b_icon_svg] }}
            </div>
          {% endif %}
          <h3 class="ib-benefit__title-{{ bid }}{% if block.settings[b_emphasize] %} ib-benefit__title-bold-{{ bid }}{% endif %}">
            {{ block.settings[b_title] }}
          </h3>
          {% if block.settings[b_text] != blank %}
            <p class="ib-benefit__text-{{ bid }}">{{ block.settings[b_text] }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {%- comment -%} ── CTA ── {%- endcomment -%}
    {% if block.settings.cta_text != blank %}
      <div class="ib-cta-wrap-{{ bid }}">
        <a
          href="{{ block.settings.cta_link | default: '#' }}"
          class="ib-cta-{{ bid }} ib-cta-{{ block.settings.cta_style }}-{{ bid }}"
        >
          {{ block.settings.cta_text }}
          {% if block.settings.cta_icon %}
            <svg class="ib-cta__arrow-{{ bid }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          {% endif %}
        </a>
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Icon Benefits + Center Media",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE BEST INGREDIENTS FOR YOUR SKIN"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Colors & Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "Max width",
      "options": [
        { "value": "1000", "label": "1000px" },
        { "value": "1100", "label": "1100px" },
        { "value": "1200", "label": "1200px" },
        { "value": "1300", "label": "1300px" }
      ],
      "default": "1200"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Center Media"
    },
    {
      "type": "select",
      "id": "center_media_type",
      "label": "Media type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video_upload", "label": "Video (Shopify hosted)" },
        { "value": "external_video", "label": "External video (YouTube/Vimeo)" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image"
    },
    {
      "type": "text",
      "id": "center_image_alt",
      "label": "Image alt text"
    },
    {
      "type": "video",
      "id": "center_video",
      "label": "Shopify hosted video"
    },
    {
      "type": "url",
      "id": "external_video_url",
      "label": "External video URL (YouTube/Vimeo)"
    },
    {
      "type": "select",
      "id": "media_aspect_ratio",
      "label": "Media aspect ratio",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "1/1", "label": "1:1 Square" },
        { "value": "4/5", "label": "4:5 Portrait" },
        { "value": "16/9", "label": "16:9 Landscape" }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Media fit",
      "options": [
        { "value": "contain", "label": "Contain" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "contain"
    },
    {
      "type": "range",
      "id": "media_border_radius",
      "label": "Media border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Video autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Video loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Video muted",
      "default": true
    },
