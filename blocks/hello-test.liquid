<div class="hello-test-block">
  <div class="hello-test-block__inner">
    <h3 class="hello-test-block__title">{{ block.settings.title }}</h3>
    <p class="hello-test-block__text">{{ block.settings.text }}</p>
    {% if block.settings.show_button %}
      <a href="{{ block.settings.button_link }}" class="hello-test-block__button">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

<style>
  .hello-test-block {
    padding: 24px;
    margin: 16px 0;
    border: 3px dashed #6366f1;
    border-radius: 12px;
    background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
    text-align: center;
  }

  .hello-test-block__inner {
    max-width: 500px;
    margin: 0 auto;
  }

  .hello-test-block__title {
    margin: 0 0 8px;
    font-size: 22px;
    font-weight: 700;
    color: #4338ca;
  }

  .hello-test-block__text {
    margin: 0 0 16px;
    font-size: 16px;
    color: #4f46e5;
    line-height: 1.5;
  }

  .hello-test-block__button {
    display: inline-block;
    padding: 10px 24px;
    background-color: #4f46e5;
    color: #ffffff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.2s;
  }

  .hello-test-block__button:hover {
    background-color: #4338ca;
  }
</style>

{% schema %}
{
  "name": "Hello Test Demo",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "🎉 Hello Test Block!"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description",
      "default": "This is a demo app block — if you can see this, it works!"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Click Me"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ]
}
{% endschema %}
