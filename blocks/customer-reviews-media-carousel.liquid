{% doc %}
  Customer Reviews Media Carousel Block
  ─────────────────────────────────────
  Enhanced testimonials carousel with media support,
  verified buyer badges, half-star ratings, RTL support,
  text truncation with read-more, compare-at pricing,
  and section heading.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-carousel__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding }}px;
    position: relative;
    overflow: hidden;
  }

  {% if block.settings.rtl_direction %}
    .ai-testimonials-carousel__wrapper-{{ ai_gen_id }} {
      direction: rtl;
    }
  {% endif %}

  .ai-testimonials-carousel__heading-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
    direction: ltr;
  }

  .ai-testimonials-carousel__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    margin: 0 0 8px 0;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-testimonials-carousel__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-testimonials-carousel__subheading-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-testimonials-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding: 8px 0;
  }

  .ai-testimonials-carousel__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-testimonials-carousel__card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    background: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-testimonials-carousel__shadow-{{ ai_gen_id }} {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .ai-testimonials-carousel__media-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }

  .ai-testimonials-carousel__media-{{ ai_gen_id }} img,
  .ai-testimonials-carousel__media-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-testimonials-carousel__content-{{ ai_gen_id }} {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
    direction: ltr;
  }

  .ai-testimonials-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
    direction: ltr;
  }

  .ai-testimonials-carousel__stars-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-testimonials-carousel__review-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: #444;
  }

  .ai-testimonials-carousel__review-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-testimonials-carousel__review-text-clamped-{{ ai_gen_id }} {
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.truncate_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-testimonials-carousel__read-more-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.accent_color }};
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
    font-size: 13px;
    text-align: left;
  }

  .ai-testimonials-carousel__author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
  }

  .ai-testimonials-carousel__avatar-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .ai-testimonials-carousel__author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-testimonials-carousel__author-name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 14px;
    color: #1a1a1a;
  }

  .ai-testimonials-carousel__author-title-{{ ai_gen_id }} {
    font-size: 12px;
    color: #888;
  }

  .ai-testimonials-carousel__verified-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #2e7d32;
    font-size: 12px;
    font-weight: 500;
  }

  .ai-testimonials-carousel__verified-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
  }

  .ai-testimonials-carousel__product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    background: #f5f5f5;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
  }

  .ai-testimonials-carousel__product-{{ ai_gen_id }} img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .ai-testimonials-carousel__product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .ai-testimonials-carousel__product-title-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-testimonials-carousel__product-price-{{ ai_gen_id }} {
    font-size: 13px;
    color: #444;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-testimonials-carousel__product-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    color: #999;
    font-size: 12px;
  }

  .ai-testimonials-carousel__purchase-note-{{ ai_gen_id }} {
    font-size: 11px;
    color: #999;
    margin-top: 2px;
  }

  .ai-testimonials-carousel__arrows-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .ai-testimonials-carousel__arrow-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .ai-testimonials-carousel__arrow-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-testimonials-carousel__arrow-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 749px) {
    .ai-testimonials-carousel__wrapper-{{ ai_gen_id }} {
      padding-left: 0;
      padding-right: 0;
    }

    .ai-testimonials-carousel__track-{{ ai_gen_id }} {
      padding-left: 16px;
      padding-right: 16px;
    }

    .ai-testimonials-carousel__card-{{ ai_gen_id }} {
      {% if block.settings.mobile_slides == '1' %}
        flex: 0 0 calc(100% - 32px);
      {% elsif block.settings.mobile_slides == '1.5' %}
        flex: 0 0 calc((100% - 32px - {{ block.settings.card_gap }}px) / 1.5);
      {% elsif block.settings.mobile_slides == '2' %}
        flex: 0 0 calc((100% - 32px - {{ block.settings.card_gap }}px) / 2);
      {% endif %}
    }
  }
{% endstyle %}

<testimonials-carousel-{{ ai_gen_id }}>
  <div class="ai-testimonials-carousel__wrapper-{{ ai_gen_id }}">

    {% if block.settings.heading_text != blank or block.settings.subheading_text != blank %}
      <div class="ai-testimonials-carousel__heading-wrapper-{{ ai_gen_id }}">
        {% if block.settings.heading_text != blank %}
          <h2 class="ai-testimonials-carousel__heading-{{ ai_gen_id }}">
            {{ block.settings.heading_text }}
          </h2>
        {% endif %}
        {% if block.settings.subheading_text != blank %}
          <div class="ai-testimonials-carousel__subheading-{{ ai_gen_id }}">
            {{ block.settings.subheading_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-carousel__track-{{ ai_gen_id }}" data-track>
      {% for i in (1..8) %}
        {% liquid
          assign enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign media_type_key = 'testimonial_' | append: i | append: '_media_type'
          assign image_key = 'testimonial_' | append: i | append: '_image'
          assign video_key = 'testimonial_' | append: i | append: '_video'
          assign rating_key = 'testimonial_' | append: i | append: '_rating'
          assign avatar_key = 'testimonial_' | append: i | append: '_avatar'
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign title_key = 'testimonial_' | append: i | append: '_title'
          assign verified_key = 'testimonial_' | append: i | append: '_verified'
          assign review_key = 'testimonial_' | append: i | append: '_review'
          assign product_key = 'testimonial_' | append: i | append: '_product'
          assign purchase_note_key = 'testimonial_' | append: i | append: '_purchase_note'

          assign is_enabled = block.settings[enabled_key]
          assign media_type = block.settings[media_type_key]
          assign t_image = block.settings[image_key]
          assign t_video = block.settings[video_key]
          assign t_rating = block.settings[rating_key]
          assign t_avatar = block.settings[avatar_key]
          assign t_name = block.settings[name_key]
          assign t_title = block.settings[title_key]
          assign t_verified = block.settings[verified_key]
          assign t_review = block.settings[review_key]
          assign t_product = block.settings[product_key]
          assign t_purchase_note = block.settings[purchase_note_key]
        %}

        {% if is_enabled %}
          <div class="ai-testimonials-carousel__card-{{ ai_gen_id }}{% if block.settings.show_card_shadow %} ai-testimonials-carousel__shadow-{{ ai_gen_id }}{% endif %}">

            {% if media_type == 'video' and t_video != blank %}
              <div class="ai-testimonials-carousel__media-{{ ai_gen_id }}">
                <video src="{{ t_video }}" autoplay muted loop playsinline></video>
              </div>
            {% elsif t_image != blank %}
              <div class="ai-testimonials-carousel__media-{{ ai_gen_id }}">
                <img
                  src="{{ t_image | image_url: width: 640 }}"
                  alt="{{ t_name | escape }}"
                  loading="lazy"
                  width="640"
                  height="480"
                >
              </div>
            {% endif %}

            <div class="ai-testimonials-carousel__content-{{ ai_gen_id }}">

              {% comment %} Stars with half-star support {% endcomment %}
              {% if t_rating > 0 %}
                <div class="ai-testimonials-carousel__stars-{{ ai_gen_id }}">
                  {% assign rating_floor = t_rating | floor %}
                  {% assign rating_decimal = t_rating | minus: rating_floor %}
                  {% assign rating_half_pos = rating_floor | plus: 1 %}
                  {% for star_i in (1..5) %}
                    {% if star_i <= rating_floor %}
                      <svg viewBox="0 0 24 24" fill="{{ block.settings.accent_color }}" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {% elsif star_i == rating_half_pos and rating_decimal > 0 %}
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                          <linearGradient id="half-star-{{ ai_gen_id }}-{{ i }}-{{ star_i }}">
                            <stop offset="50%" stop-color="{{ block.settings.accent_color }}" />
                            <stop offset="50%" stop-color="#E0E0E0" />
                          </linearGradient>
                        </defs>
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#half-star-{{ ai_gen_id }}-{{ i }}-{{ star_i }})"/>
                      </svg>
                    {% else %}
                      <svg viewBox="0 0 24 24" fill="#E0E0E0" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% comment %} Review text with truncation {% endcomment %}
              {% if t_review != blank %}
                <div class="ai-testimonials-carousel__review-{{ ai_gen_id }} ai-testimonials-carousel__review-text-clamped-{{ ai_gen_id }}" data-review-text>
                  {{ t_review }}
                </div>
                {% if block.settings.show_read_more %}
                  <button type="button" class="ai-testimonials-carousel__read-more-{{ ai_gen_id }}" data-read-more>Read more</button>
                {% endif %}
              {% endif %}

              {% comment %} Author info {% endcomment %}
              <div class="ai-testimonials-carousel__author-{{ ai_gen_id }}">
                {% if t_avatar != blank %}
                  <img
                    class="ai-testimonials-carousel__avatar-{{ ai_gen_id }}"
                    src="{{ t_avatar | image_url: width: 80 }}"
                    alt="{{ t_name | escape }}"
                    loading="lazy"
                    width="40"
                    height="40"
                  >
                {% endif %}
                <div class="ai-testimonials-carousel__author-info-{{ ai_gen_id }}">
                  {% if t_name != blank %}
                    <span class="ai-testimonials-carousel__author-name-{{ ai_gen_id }}">{{ t_name }}</span>
                  {% endif %}
                  {% if t_title != blank %}
                    <span class="ai-testimonials-carousel__author-title-{{ ai_gen_id }}">{{ t_title }}</span>
                  {% endif %}
                </div>
              </div>

              {% comment %} Verified buyer badge {% endcomment %}
              {% if t_verified %}
                <span class="ai-testimonials-carousel__verified-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  Verified Buyer
                </span>
              {% endif %}

              {% comment %} Product card {% endcomment %}
              {% if t_product != blank %}
                {% assign product = t_product %}
                <a href="{{ product.url }}" class="ai-testimonials-carousel__product-{{ ai_gen_id }}">
                  {% if product.featured_image != blank %}
                    <img
                      src="{{ product.featured_image | image_url: width: 96 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                      width="48"
                      height="48"
                    >
                  {% endif %}
                  <div class="ai-testimonials-carousel__product-info-{{ ai_gen_id }}">
                    <span class="ai-testimonials-carousel__product-title-{{ ai_gen_id }}">{{ product.title }}</span>
                    <span class="ai-testimonials-carousel__product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                      {% if product.compare_at_price > product.price %}
                        <span class="ai-testimonials-carousel__product-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                    </span>
                    {% if t_purchase_note != blank %}
                      <span class="ai-testimonials-carousel__purchase-note-{{ ai_gen_id }}">{{ t_purchase_note }}</span>
                    {% endif %}
                  </div>
                </a>
              {% endif %}

            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <div class="ai-testimonials-carousel__arrows-{{ ai_gen_id }}">
        <button type="button" class="ai-testimonials-carousel__arrow-{{ ai_gen_id }}" data-arrow="prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button type="button" class="ai-testimonials-carousel__arrow-{{ ai_gen_id }}" data-arrow="next" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {% endif %}

  </div>
</testimonials-carousel-{{ ai_gen_id }}>

<script>
  (function () {
    const TAG = 'testimonials-carousel-{{ ai_gen_id }}';

    if (customElements.get(TAG)) return;

    class TestimonialsCarousel extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        if (!this.track) return;

        this.initArrows();
        this.initReadMore();
        this.centerTrack();
        this._onResize = () => this.centerTrack();
        window.addEventListener('resize', this._onResize);
      }

      disconnectedCallback() {
        if (this._onResize) {
          window.removeEventListener('resize', this._onResize);
        }
      }

      centerTrack() {
        if (this.track.scrollWidth <= this.track.clientWidth) {
          this.track.style.justifyContent = 'center';
        } else {
          this.track.style.justifyContent = '';
        }
      }

      initArrows() {
        const arrows = this.querySelectorAll('[data-arrow]');
        if (!arrows.length) return;

        const wrapper = this.track.closest('[class*="__wrapper"]');
        const isRTL = wrapper && getComputedStyle(wrapper).direction === 'rtl';
        const scrollAmount = 340;

        arrows.forEach((arrow) => {
          arrow.addEventListener('click', () => {
            const dir = arrow.getAttribute('data-arrow');
            let delta = scrollAmount;

            if (dir === 'prev') {
              delta = -scrollAmount;
            }

            if (isRTL) {
              delta = -delta;
            }

            this.track.scrollBy({ left: delta, behavior: 'smooth' });
          });
        });
      }

      initReadMore() {
        const buttons = this.querySelectorAll('[data-read-more]');

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const textEl = btn.previousElementSibling;
            if (!textEl) return;

            const clampClass = Array.from(textEl.classList).find((c) =>
              c.indexOf('review-text-clamped') !== -1
            );

            if (!clampClass) return;

            if (textEl.classList.contains(clampClass)) {
              textEl.classList.remove(clampClass);
              btn.textContent = 'Read less';
            } else {
              textEl.classList.add(clampClass);
              btn.textContent = 'Read more';
            }
          });
        });
      }
    }

    customElements.define(TAG, TestimonialsCarousel);
  })();
</script>

{% schema %}
{
  "name": "Reviews Media Carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "What our clients say"
    },
    {
      "type": "richtext",
      "id": "subheading_text",
      "label": "Subheading",
      "default": "<p>Real reviews from real customers</p>"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#F9F7F4"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 20,
      "max": 80,
      "step": 10,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C8A97E"
    },
    {
      "type": "checkbox",
      "id": "rtl_direction",
      "label": "RTL direction",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_shadow",
      "label": "Show card shadow",
      "default": true
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width",
      "min": 250,
      "max": 500,
      "step": 10,
      "default": 320,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "mobile_slides",
      "label": "Slides visible on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "1.5",
          "label": "1.5"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "header",
      "content": "Text Truncation"
    },
    {
      "type": "range",
      "id": "truncate_lines",
      "label": "Truncate lines",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "Show read more button",
      "default": true
    },
    {
      "type": "header",
      "content": "Navigation Arrows"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Arrow background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#1a1a1a"
    },
