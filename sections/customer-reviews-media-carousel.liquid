        {%- if section.settings.heading != blank -%}
          <h2 class="rc-heading">
            {%- assign accent_words = section.settings.heading_accent_words | split: ',' -%}
            {%- assign heading_text = section.settings.heading -%}
            {%- for word in accent_words -%}
              {%- assign trimmed = word | strip -%}
              {%- if trimmed != blank -%}
                {%- capture accent_span -%}<span class="rc-accent">{{ trimmed }}</span>{%- endcapture -%}
                {%- assign heading_text = heading_text | replace: trimmed, accent_span -%}
              {%- endif -%}
            {%- endfor -%}
            {{- heading_text -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="rc-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="rc-carousel-wrap">
      {%- if section.settings.show_arrows -%}
        <button class="rc-arrow rc-arrow--prev" aria-label="Previous slide" data-dir="prev">
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <button class="rc-arrow rc-arrow--next" aria-label="Next slide" data-dir="next">
