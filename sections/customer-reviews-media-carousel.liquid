{% assign section_id = section.id %}

<style>
  #reviews-carousel-{{ section_id }} {
    --rc-bg: {{ section.settings.background_color }};
    --rc-heading-color: {{ section.settings.heading_color }};
    --rc-text-color: {{ section.settings.text_color }};
    --rc-star-color: {{ section.settings.star_color }};
    --rc-card-border: {{ section.settings.card_border_color }};
    --rc-card-radius: {{ section.settings.card_radius }}px;
    --rc-desktop-cards: {{ section.settings.desktop_cards_per_view }};
    --rc-mobile-cards: {{ section.settings.mobile_cards_per_view }};
    --rc-media-ratio: {{ section.settings.media_aspect_ratio }};
    padding: 50px 0;
    background-color: var(--rc-bg);
    color: var(--rc-text-color);
    direction: rtl;
  }

  #reviews-carousel-{{ section_id }} .rc-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Header */
  #reviews-carousel-{{ section_id }} .rc-header {
    text-align: center;
    margin-bottom: 40px;
  }

  #reviews-carousel-{{ section_id }} .rc-heading {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--rc-heading-color);
    margin: 0 0 12px;
    line-height: 1.2;
  }

  #reviews-carousel-{{ section_id }} .rc-heading .rc-accent {
    color: var(--rc-star-color);
  }

  #reviews-carousel-{{ section_id }} .rc-subheading {
    font-size: 1.05rem;
    color: var(--rc-text-color);
    opacity: 0.75;
    margin: 0;
    line-height: 1.5;
  }

  /* Carousel wrapper */
  #reviews-carousel-{{ section_id }} .rc-carousel-wrap {
    position: relative;
  }

  #reviews-carousel-{{ section_id }} .rc-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }

  #reviews-carousel-{{ section_id }} .rc-track.rc-hide-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #reviews-carousel-{{ section_id }} .rc-track.rc-hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  #reviews-carousel-{{ section_id }} .rc-track::-webkit-scrollbar {
    height: 6px;
  }

  #reviews-carousel-{{ section_id }} .rc-track::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.06);
    border-radius: 3px;
  }

  #reviews-carousel-{{ section_id }} .rc-track::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 3px;
  }

  /* Card */
  #reviews-carousel-{{ section_id }} .rc-card {
    flex: 0 0 calc((100% - 20px * (var(--rc-desktop-cards) - 1)) / var(--rc-desktop-cards));
    scroll-snap-align: start;
    border: 1px solid var(--rc-card-border);
    border-radius: var(--rc-card-radius);
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
  }

  #reviews-carousel-{{ section_id }} .rc-card.rc-card--shadow {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  /* Media */
  #reviews-carousel-{{ section_id }} .rc-media-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: var(--rc-media-ratio);
    overflow: hidden;
    background: #f0f0f0;
  }

  #reviews-carousel-{{ section_id }} .rc-media-wrap img,
  #reviews-carousel-{{ section_id }} .rc-media-wrap video,
  #reviews-carousel-{{ section_id }} .rc-media-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  #reviews-carousel-{{ section_id }} .rc-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s;
  }

  #reviews-carousel-{{ section_id }} .rc-play-overlay:hover {
    background: rgba(0, 0, 0, 0.35);
  }

  #reviews-carousel-{{ section_id }} .rc-play-overlay svg {
    width: 56px;
    height: 56px;
    fill: #fff;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
  }

  /* Card body */
  #reviews-carousel-{{ section_id }} .rc-body {
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Stars */
  #reviews-carousel-{{ section_id }} .rc-stars {
    display: flex;
    gap: 3px;
    margin-bottom: 10px;
    direction: ltr;
  }

  #reviews-carousel-{{ section_id }} .rc-stars svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  #reviews-carousel-{{ section_id }} .rc-star-full {
    fill: var(--rc-star-color);
  }

  #reviews-carousel-{{ section_id }} .rc-star-empty {
    fill: #ddd;
  }

  /* Reviewer info */
  #reviews-carousel-{{ section_id }} .rc-reviewer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  #reviews-carousel-{{ section_id }} .rc-reviewer-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  #reviews-carousel-{{ section_id }} .rc-reviewer-age {
    font-size: 0.85rem;
    opacity: 0.6;
  }

  #reviews-carousel-{{ section_id }} .rc-verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.78rem;
    color: #2e7d32;
    font-weight: 500;
  }

  #reviews-carousel-{{ section_id }} .rc-verified svg {
    width: 14px;
    height: 14px;
    fill: #2e7d32;
  }

  /* Review text */
  #reviews-carousel-{{ section_id }} .rc-text {
    font-size: 0.92rem;
    line-height: 1.55;
    margin-bottom: 6px;
    flex: 1;
  }

  #reviews-carousel-{{ section_id }} .rc-text-clamped {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #reviews-carousel-{{ section_id }} .rc-read-more {
    background: none;
    border: none;
    padding: 0;
    color: var(--rc-star-color);
    font-size: 0.85rem;
    cursor: pointer;
    font-weight: 600;
    margin-bottom: 10px;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  #reviews-carousel-{{ section_id }} .rc-read-more:hover {
    opacity: 0.8;
  }

  /* Product mini-card */
  #reviews-carousel-{{ section_id }} .rc-product {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-top: 1px solid var(--rc-card-border);
    background: #fafafa;
    margin-top: auto;
  }

  #reviews-carousel-{{ section_id }} .rc-product-img {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: #eee;
  }

  #reviews-carousel-{{ section_id }} .rc-product-info {
    flex: 1;
    min-width: 0;
  }

  #reviews-carousel-{{ section_id }} .rc-product-title {
    font-size: 0.82rem;
    font-weight: 600;
    margin: 0 0 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #reviews-carousel-{{ section_id }} .rc-product-title a {
    color: inherit;
    text-decoration: none;
  }

  #reviews-carousel-{{ section_id }} .rc-product-title a:hover {
    text-decoration: underline;
  }

  #reviews-carousel-{{ section_id }} .rc-product-pricing {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    direction: ltr;
  }

  #reviews-carousel-{{ section_id }} .rc-product-price {
    font-weight: 700;
  }

  #reviews-carousel-{{ section_id }} .rc-product-compare {
    text-decoration: line-through;
    opacity: 0.5;
    font-size: 0.78rem;
  }

  #reviews-carousel-{{ section_id }} .rc-purchase-note {
    font-size: 0.75rem;
    opacity: 0.55;
    margin-top: 2px;
  }

  /* Arrows */
  #reviews-carousel-{{ section_id }} .rc-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--rc-card-border);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: box-shadow 0.2s, background 0.2s;
  }

  #reviews-carousel-{{ section_id }} .rc-arrow:hover {
    background: #f5f5f5;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.14);
  }

  #reviews-carousel-{{ section_id }} .rc-arrow:focus-visible {
    outline: 2px solid var(--rc-star-color);
    outline-offset: 2px;
  }

  #reviews-carousel-{{ section_id }} .rc-arrow svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #reviews-carousel-{{ section_id }} .rc-arrow--next {
    left: -21px;
  }

  #reviews-carousel-{{ section_id }} .rc-arrow--prev {
    right: -21px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    #reviews-carousel-{{ section_id }} .rc-card {
      flex: 0 0 calc((100% - 20px * (var(--rc-mobile-cards) - 1)) / var(--rc-mobile-cards));
    }

    #reviews-carousel-{{ section_id }} .rc-heading {
      font-size: 1.7rem;
    }

    #reviews-carousel-{{ section_id }} .rc-arrow {
      display: none;
    }

    #reviews-carousel-{{ section_id }} {
      padding: 36px 0;
    }
  }
</style>

<div id="reviews-carousel-{{ section_id }}">
  <div class="rc-container">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="rc-header">
        {% if section.settings.heading != blank %}
          <h2 class="rc-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <div class="rc-subheading">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="rc-carousel-wrap">
      {% if section.settings.show_arrows %}
        <button class="rc-arrow rc-arrow--prev" aria-label="Previous slide" data-dir="prev">
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <button class="rc-arrow rc-arrow--next" aria-label="Next slide" data-dir="next">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
      {% endif %}

      <div
        class="rc-track{% unless section.settings.show_scrollbar %} rc-hide-scrollbar{% endunless %}"
        role="region"
        aria-label="{{ section.settings.heading | default: 'Customer reviews carousel' }}"
        tabindex="0"
      >

        <!-- Review Card 1 -->
        {% if section.settings.review_1_name != blank %}
          <div class="rc-card{% if section.settings.card_shadow %} rc-card--shadow{% endif %}">
            <div class="rc-media-wrap">
              {% if section.settings.review_1_media_type == 'image' %}
                {% if section.settings.review_1_image != blank %}
                  <img
                    src="{{ section.settings.review_1_image | image_url: width: 800 }}"
                    alt="{{ section.settings.review_1_image_alt | escape }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: section.settings.review_1_image.aspect_ratio | round }}"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              {% elsif section.settings.review_1_media_type == 'video_upload' %}
                {% if section.settings.review_1_video != blank %}
                  <video
                    playsinline
                    {% if section.settings.review_1_video_autoplay %}autoplay{% endif %}
                    {% if section.settings.review_1_video_loop %}loop{% endif %}
                    {% if section.settings.review_1_video_muted %}muted{% endif %}
                    {% if section.settings.review_1_image != blank %}poster="{{ section.settings.review_1_image | image_url: width: 800 }}"{% endif %}
                    data-fallback-img="{% if section.settings.review_1_image != blank %}{{ section.settings.review_1_image | image_url: width: 800 }}{% endif %}"
                  >
                    {% for source in section.settings.review_1_video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>
                {% endif %}
                {% if section.settings.review_1_show_play_icon %}
                  <div class="rc-play-overlay" aria-label="Play video" role="button" tabindex="0">
                    <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
                  </div>
                {% endif %}
              {% elsif section.settings.review_1_media_type == 'external_video' %}
                {% if section.settings.review_1_external_video_url != blank %}
                  {% if section.settings.review_1_external_video_url contains 'youtube.com' or section.settings.review_1_external_video_url contains 'youtu.be' %}
                    {% assign yt_id_1 = section.settings.review_1_external_video_url | split: 'v=' | last | split: '&' | first %}
                    <iframe
                      src="https://www.youtube.com/embed/{{ yt_id_1 }}?playsinline=1&rel=0"
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                      title="{{ section.settings.review_1_name }} video"
                    ></iframe>
                  {% elsif section.settings.review_1_external_video_url contains 'vimeo.com' %}
                    {% assign vimeo_id_1 = section.settings.review_1_external_video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first %}
                    <iframe
                      src="https://player.vimeo.com/video/{{ vimeo_id_1 }}?playsinline=1"
                      allow="autoplay; fullscreen; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                      title="{{ section.settings.review_1_name }} video"
                    ></iframe>
                  {% endif %}
                {% endif %}
              {% endif %}
            </div>
            <div class="rc-body">
              <div class="rc-stars" role="img" aria-label="{{ section.settings.review_1_rating }} out of 5 stars">
                {% for s in (1..5) %}
                  {% assign half_1 = s | minus: 0.5 %}
                  {% if section.settings.review_1_rating >= s %}
                    <svg viewBox="0 0 24 24"><path class="rc-star-full" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% elsif section.settings.review_1_rating >= half_1 %}
                    <svg viewBox="0 0 24 24">
                      <defs><linearGradient id="half-{{ section_id }}-1-{{ s }}"><stop offset="50%" stop-color="var(--rc-star-color)"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs>
                      <path fill="url(#half-{{ section_id }}-1-{{ s }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24"><path class="rc-star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endif %}
                {% endfor %}
              </div>
              <div class="rc-reviewer">
                <span class="rc-reviewer-name">{{ section.settings.review_1_name }}</span>
                {% if section.settings.review_1_age != blank %}
                  <span class="rc-reviewer-age">{{ section.settings.review_1_age }}</span>
                {% endif %}
                {% if section.settings.review_1_verified %}
                  <span class="rc-verified">
                    <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                    Verified Buyer
                  </span>
                {% endif %}
              </div>
              {% if section.settings.review_1_text != blank %}
                <div class="rc-text rc-text-clamped" style="-webkit-line-clamp: {{ section.settings.review_1_truncate_lines }};" data-truncate="{{ section.settings.review_1_truncate_lines }}">
                  {{ section.settings.review_1_text }}
                </div>
                {% if section.settings.review_1_show_read_more %}
                  <button class="rc-read-more" data-expanded="false">Read more</button>
                {% endif %}
              {% endif %}
              {% if section.settings.review_1_product != blank %}
                <div class="rc-product">
                  {% if section.settings.review_1_product.featured_image != blank %}
                    <img class="rc-product-img" src="{{ section.settings.review_1_product.featured_image | image_url: width: 120 }}" alt="{{ section.settings.review_1_product.featured_image.alt | escape }}" loading="lazy" width="56" height="56">
                  {% endif %}
                  <div class="rc-product-info">
                    <p class="rc-product-title"><a href="{{ section.settings.review_1_product.url }}">{{ section.settings.review_1_product.title }}</a></p>
                    <div class="rc-product-pricing">
                      <span class="rc-product-price">{{ section.settings.review_1_product.price | money }}</span>
                      {% if section.settings.review_1_show_compare_price and section.settings.review_1_product.compare_at_price > section.settings.review_1_product.price %}
                        <span class="rc-product-compare">{{ section.settings.review_1_product.compare_at_price | money }}</span>
                      {% endif %}
                    </div>
                    {% if section.settings.review_1_purchase_note != blank %}
                      <div class="rc-purchase-note">{{ section.settings.review_1_purchase_note }}</div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}

        <!-- Review Card 2 -->
        {% if section.settings.review_2_name != blank %}
          <div class="rc-card{% if section.settings.card_shadow %} rc-card--shadow{% endif %}">
            <div class="rc-media-wrap">
              {% if section.settings.review_2_media_type == 'image' %}
                {% if section.settings.review_2_image != blank %}
                  <img
                    src="{{ section.settings.review_2_image | image_url: width: 800 }}"
                    alt="{{ section.settings.review_2_image_alt | escape }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: section.settings.review_2_image.aspect_ratio | round }}"
                  >
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              {% elsif section.settings.review_2_media_type == 'video_upload' %}
                {% if section.settings.review_2_video != blank %}
                  <video
                    playsinline
                    {% if section.settings.review_2_video_autoplay %}autoplay{% endif %}
                    {% if section.settings.review_2_video_loop %}loop{% endif %}
                    {% if section.settings.review_2_video_muted %}muted{% endif %}
                    {% if section.settings.review_2_image != blank %}poster="{{ section.settings.review_2_image | image_url: width: 800 }}"{% endif %}
                    data-fallback-img="{% if section.settings.review_2_image != blank %}{{ section.settings.review_2_image | image_url: width: 800 }}{% endif %}"
                  >
                    {% for source in section.settings.review_2_video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>
                {% endif %}
                {% if section.settings.review_2_show_play_icon %}
                  <div class="rc-play-overlay" aria-label="Play video" role="button" tabindex="0">
                    <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
                  </div>
                {% endif %}
              {% elsif section.settings.review_2_media_type == 'external_video' %}
                {% if section.settings.review_2_external_video_url != blank %}
                  {% if section.settings.review_2_external_video_url contains 'youtube.com' or section.settings.review_2_external_video_url contains 'youtu.be' %}
                    {% assign yt_id_2 = section.settings.review_2_external_video_url | split: 'v=' | last | split: '&' | first %}
                    <iframe
                      src="https://www.youtube.com/embed/{{ yt_id_2 }}?playsinline=1&rel=0"
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                      title="{{ section.settings.review_2_name }} video"
                    ></iframe>
                  {% elsif section.settings.review_2_external_video_url contains 'vimeo.com' %}
                    {% assign vimeo_id_2 = section.settings.review_2_external_video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first %}
                    <iframe
                      src="https://player.vimeo.com/video/{{ vimeo_id_2 }}?playsinline=1"
                      allow="autoplay; fullscreen; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                      title="{{ section.settings.review_2_name }} video"
                    ></iframe>
                  {% endif %}
                {% endif %}
              {% endif %}
            </div>
            <div class="rc-body">
              <div class="rc-stars" role="img" aria-label="{{ section.settings.review_2_rating }} out of 5 stars">
                {% for s in (1..5) %}
                  {% assign half_2 = s | minus: 0.5 %}
                  {% if section.settings.review_2_rating >= s %}
                    <svg viewBox="0 0 24 24"><path class="rc-star-full" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% elsif section.settings.review_2_rating >= half_2 %}
                    <svg viewBox="0 0 24 24">
                      <defs><linearGradient id="half-{{ section_id }}-2-{{ s }}"><stop offset="50%" stop-color="var(--rc-star-color)"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs>
                      <path fill="url(#half-{{ section_id }}-2-{{ s }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24"><path class="rc-star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endif %}
                {% endfor %}
              </div>
              <div class="rc-reviewer">
                <span class="rc-reviewer-name">{{ section.settings.review_2_name }}</span>
                {% if section.settings.review_2_age != blank %}
                  <span class="rc-reviewer-age">{{ section.settings.review_2_age }}</span>
                {% endif %}
                {% if section.settings.review_2_verified %}
                  <span class="rc-verified">
                    <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                    Verified Buyer
                  </span>
                {% endif %}
              </div>
              {% if section.settings.review_2_text != blank %}
