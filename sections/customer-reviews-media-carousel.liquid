    <p style="color:red !important;font-size:30px !important;display:block !important;visibility:visible !important;opacity:1 !important;position:relative !important;z-index:9999 !important;">DEBUG: section renders HTML</p>
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
