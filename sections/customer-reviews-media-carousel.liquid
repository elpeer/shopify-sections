<script>
  (function () {
    var section = document.getElementById('reviews-carousel-{{ section_id }}');
    if (!section) return;

    var track = section.querySelector('.rc-track');

    /* --- Arrows --- */
    var arrows = section.querySelectorAll('.rc-arrow');
    if (arrows.length) {
      arrows.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var card = track.querySelector('.rc-card');
          if (!card) return;
          var scrollAmount = card.offsetWidth + 20;
          var dir = btn.getAttribute('data-dir');
          if (dir === 'next') {
            track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          }
        });
      });
    }

    /* --- Read more toggle --- */
    var readMoreBtns = section.querySelectorAll('.rc-read-more');
    readMoreBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var textEl = btn.previousElementSibling;
        if (!textEl) return;
        var expanded = btn.getAttribute('data-expanded') === 'true';
        if (expanded) {
          textEl.classList.add('rc-text-clamped');
          textEl.style.webkitLineClamp = textEl.getAttribute('data-truncate');
          btn.setAttribute('data-expanded', 'false');
          btn.textContent = 'Read more';
        } else {
          textEl.classList.remove('rc-text-clamped');
          textEl.style.webkitLineClamp = 'unset';
          btn.setAttribute('data-expanded', 'true');
          btn.textContent = 'Read less';
        }
      });
    });

    /* --- Play overlay for hosted videos --- */
    var overlays = section.querySelectorAll('.rc-play-overlay');
    overlays.forEach(function (overlay) {
      function triggerPlay() {
        var video = overlay.parentElement.querySelector('video');
        if (video) {
          video.play();
          overlay.style.display = 'none';
        }
      }
      overlay.addEventListener('click', triggerPlay);
      overlay.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          triggerPlay();
        }
      });
    });

    /* --- Video error fallback --- */
    var videos = section.querySelectorAll('video');
    videos.forEach(function (video) {
      video.addEventListener('error', function () {
        var fallback = video.getAttribute('data-fallback-img');
        if (fallback) {
          var img = document.createElement('img');
          img.src = fallback;
          img.alt = 'Review media';
          img.loading = 'lazy';
          img.style.objectFit = 'cover';
          video.parentElement.appendChild(img);
          video.remove();
        }
      });
    });
  })();
</script>

