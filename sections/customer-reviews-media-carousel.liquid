              {%- assign r_play_icon = section.settings.review_8_show_play_icon -%}
          {%- endcase -%}

          {%- if reviewer_name != blank -%}
            <div class="rc-card{% if section.settings.card_shadow %} rc-card--shadow{% endif %}">
              {%- comment -%}--- MEDIA ---{%- endcomment -%}
              <div class="rc-media-wrap">
                {%- case r_media -%}
                  {%- when 'image' -%}
                    {%- if r_image != blank -%}
                      <img
                        src="{{ r_image | image_url: width: 800 }}"
                        alt="{{ r_alt | escape }}"
                        loading="lazy"
                        width="800"
                        height="{{ 800 | divided_by: r_image.aspect_ratio | round }}"
                      >
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}

                  {%- when 'video_upload' -%}
                    {%- if r_video != blank -%}
                      <video
                        playsinline
                        {% if r_autoplay %}autoplay{% endif %}
                        {% if r_loop %}loop{% endif %}
                        {% if r_muted %}muted{% endif %}
                        {% if r_image != blank %}poster="{{ r_image | image_url: width: 800 }}"{% endif %}
                        data-fallback-img="{% if r_image != blank %}{{ r_image | image_url: width: 800 }}{% endif %}"
                      >
                        {%- for source in r_video.sources -%}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {%- endfor -%}
                      </video>
                    {%- endif -%}
                    {%- if r_play_icon -%}
                      <div class="rc-play-overlay" aria-label="Play video" role="button" tabindex="0">
                        <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
                      </div>
                    {%- endif -%}

                  {%- when 'external_video' -%}
                    {%- if r_ext != blank -%}
                      {%- if r_ext contains 'youtube.com' or r_ext contains 'youtu.be' -%}
                        {%- if r_ext contains 'youtu.be' -%}
                          {%- assign yt_id = r_ext | split: 'youtu.be/' | last | split: '?' | first -%}
                        {%- else -%}
                          {%- assign yt_id = r_ext | split: 'v=' | last | split: '&' | first -%}
                        {%- endif -%}
                        <iframe
                          src="https://www.youtube.com/embed/{{ yt_id }}?{% if r_autoplay %}autoplay=1&{% endif %}{% if r_muted %}mute=1&{% endif %}{% if r_loop %}loop=1&playlist={{ yt_id }}&{% endif %}playsinline=1&rel=0"
                          allow="autoplay; encrypted-media; picture-in-picture"
                          allowfullscreen
                          loading="lazy"
                          title="{{ reviewer_name | default: 'Review' }} video"
                        ></iframe>
                      {%- elsif r_ext contains 'vimeo.com' -%}
                        {%- assign vimeo_id = r_ext | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first -%}
                        <iframe
                          src="https://player.vimeo.com/video/{{ vimeo_id }}?{% if r_autoplay %}autoplay=1&{% endif %}{% if r_muted %}muted=1&{% endif %}{% if r_loop %}loop=1&{% endif %}playsinline=1"
                          allow="autoplay; fullscreen; picture-in-picture"
                          allowfullscreen
                          loading="lazy"
                          title="{{ reviewer_name | default: 'Review' }} video"
                        ></iframe>
                      {%- endif -%}
                    {%- endif -%}
                    {%- if r_play_icon -%}
                      <div class="rc-play-overlay" aria-label="Play video" role="button" tabindex="0">
                        <svg viewBox="0 0 64 64"><path d="M24 16 L48 32 L24 48 Z"/></svg>
                      </div>
                    {%- endif -%}
                {%- endcase -%}
              </div>

              {%- comment -%}--- CARD BODY ---{%- endcomment -%}
              <div class="rc-body">
                {%- comment -%}Stars{%- endcomment -%}
                <div class="rc-stars" role="img" aria-label="{{ r_rating }} out of 5 stars">
                  {%- for s in (1..5) -%}
                    {%- assign half_threshold = s | minus: 0.5 -%}
                    {%- if r_rating >= s -%}
                      <svg viewBox="0 0 24 24"><path class="rc-star-full" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {%- elsif r_rating >= half_threshold -%}
                      <svg viewBox="0 0 24 24">
                        <defs><linearGradient id="half-{{ section_id }}-{{ i }}-{{ s }}"><stop offset="50%" stop-color="var(--rc-star-color)"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs>
                        <path fill="url(#half-{{ section_id }}-{{ i }}-{{ s }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24"><path class="rc-star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- comment -%}Reviewer{%- endcomment -%}
                <div class="rc-reviewer">
                  <span class="rc-reviewer-name">{{ reviewer_name }}</span>
                  {%- if r_age != blank -%}
                    <span class="rc-reviewer-age">{{ r_age }}</span>
                  {%- endif -%}
                  {%- if r_verified -%}
                    <span class="rc-verified">
                      <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                      Verified Buyer
                    </span>
                  {%- endif -%}
                </div>

                {%- comment -%}Review text{%- endcomment -%}
                {%- if r_text != blank -%}
                  <div
                    class="rc-text rc-text-clamped"
                    style="-webkit-line-clamp: {{ r_truncate }};"
                    data-truncate="{{ r_truncate }}"
                  >
                    {{ r_text }}
                  </div>
                  {%- if r_readmore -%}
                    <button class="rc-read-more" data-expanded="false">Read more</button>
                  {%- endif -%}
                {%- endif -%}

                {%- comment -%}Purchased product{%- endcomment -%}
                {%- if r_product != blank -%}
                  <div class="rc-product">
                    {%- if r_product.featured_image != blank -%}
                      <img
                        class="rc-product-img"
                        src="{{ r_product.featured_image | image_url: width: 120 }}"
                        alt="{{ r_product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="56"
                        height="56"
                      >
                    {%- endif -%}
                    <div class="rc-product-info">
                      <p class="rc-product-title">
                        <a href="{{ r_product.url }}">{{ r_product.title }}</a>
                      </p>
                      <div class="rc-product-pricing">
                        <span class="rc-product-price">{{ r_product.price | money }}</span>
                        {%- if r_compare and r_product.compare_at_price > r_product.price -%}
                          <span class="rc-product-compare">{{ r_product.compare_at_price | money }}</span>
                        {%- endif -%}
                      </div>
                      {%- if r_note != blank -%}
                        <div class="rc-purchase-note">{{ r_note }}</div>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var section = document.getElementById('reviews-carousel-{{ section_id }}');
    if (!section) return;

    var track = section.querySelector('.rc-track');

    /* --- Arrows --- */
    var arrows = section.querySelectorAll('.rc-arrow');
    if (arrows.length) {
      arrows.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var card = track.querySelector('.rc-card');
          if (!card) return;
          var scrollAmount = card.offsetWidth + 20;
          var dir = btn.getAttribute('data-dir');
          if (dir === 'next') {
            track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          }
        });
      });
    }

    /* --- Read more toggle --- */
    var readMoreBtns = section.querySelectorAll('.rc-read-more');
    readMoreBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var textEl = btn.previousElementSibling;
        if (!textEl) return;
        var expanded = btn.getAttribute('data-expanded') === 'true';
        if (expanded) {
          textEl.classList.add('rc-text-clamped');
          textEl.style.webkitLineClamp = textEl.getAttribute('data-truncate');
          btn.setAttribute('data-expanded', 'false');
          btn.textContent = 'Read more';
        } else {
          textEl.classList.remove('rc-text-clamped');
          textEl.style.webkitLineClamp = 'unset';
          btn.setAttribute('data-expanded', 'true');
          btn.textContent = 'Read less';
        }
      });
    });

    /* --- Play overlay for hosted videos --- */
    var overlays = section.querySelectorAll('.rc-play-overlay');
    overlays.forEach(function (overlay) {
      function triggerPlay() {
        var video = overlay.parentElement.querySelector('video');
        if (video) {
          video.play();
          overlay.style.display = 'none';
        }
      }
      overlay.addEventListener('click', triggerPlay);
      overlay.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          triggerPlay();
        }
      });
    });

    /* --- Video error fallback --- */
    var videos = section.querySelectorAll('video');
    videos.forEach(function (video) {
      video.addEventListener('error', function () {
        var fallback = video.getAttribute('data-fallback-img');
        if (fallback) {
          var img = document.createElement('img');
          img.src = fallback;
          img.alt = 'Review media';
          img.loading = 'lazy';
          img.style.objectFit = 'cover';
          video.parentElement.appendChild(img);
          video.remove();
        }
      });
    });
  })();
</script>

