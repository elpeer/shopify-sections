{% assign mg_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .mg-section-{{ mg_id }} {
    width: 100%;
    display: block;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .mg-container-{{ mg_id }} {
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .mg-grid-{{ mg_id }} {
    display: grid;
    {% if section.settings.gap_size == 'none' %}
      gap: 0;
    {% else %}
      gap: {{ section.settings.gap_size }}px;
    {% endif %}
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  }

  {% if section.settings.grid_height_mode == 'same' %}
    .mg-grid-{{ mg_id }} .mg-item-{{ mg_id }} {
      height: {{ section.settings.grid_item_height }}px;
    }
  {% endif %}

  .mg-slider-{{ mg_id }} {
    position: relative;
    overflow: hidden;
    max-height: {{ section.settings.slider_max_height }}px;
  }

  .mg-slider-track-{{ mg_id }} {
    display: flex;
    transition: transform 0.4s ease;
    {% if section.settings.gap_size == 'none' %}
      gap: 0;
    {% else %}
      gap: {{ section.settings.gap_size }}px;
    {% endif %}
  }

  .mg-slider-track-{{ mg_id }} .mg-item-{{ mg_id }} {
    flex: 0 0 100%;
    max-width: 100%;
  }

  .mg-item-{{ mg_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ section.settings.media_bg_color }};
    border-radius: {{ section.settings.media_border_radius }}px;
  }

  {% if section.settings.grid_height_mode == 'auto' %}
    .mg-item-{{ mg_id }} {
      aspect-ratio: 16 / 9;
    }
  {% endif %}

  .mg-item-{{ mg_id }} img,
  .mg-item-{{ mg_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mg-hidden-{{ mg_id }} {
    display: none;
  }

  .mg-show-more-{{ mg_id }} {
    margin-top: 20px;
    text-align: center;
  }

  .mg-show-more-btn-{{ mg_id }} {
    padding: 12px 30px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border: 1px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .mg-show-more-btn-{{ mg_id }}:hover {
    background-color: {{ section.settings.button_hover_bg_color }};
    color: {{ section.settings.button_hover_text_color }};
  }

  .mg-slider-nav-{{ mg_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ section.settings.nav_bg_color }};
    color: {{ section.settings.nav_icon_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  .mg-slider-nav-{{ mg_id }}:hover {
    opacity: 0.8;
  }

  .mg-slider-nav-{{ mg_id }}--prev {
    left: 10px;
  }

  .mg-slider-nav-{{ mg_id }}--next {
    right: 10px;
  }

  .mg-slider-nav-{{ mg_id }} svg {
    width: 20px;
    height: 20px;
  }

  .mg-slider-dots-{{ mg_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 15px;
  }

  .mg-slider-dot-{{ mg_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_inactive_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease;
  }

  .mg-slider-dot-{{ mg_id }}.active {
    background-color: {{ section.settings.dot_active_color }};
  }

  .mg-empty-{{ mg_id }} {
    text-align: center;
    padding: 60px 20px;
    background-color: #f4f4f4;
    border-radius: 8px;
  }

  .mg-empty-{{ mg_id }} svg {
    width: 80px;
    height: 80px;
    margin: 0 auto 15px;
    opacity: 0.3;
  }

  .mg-empty-text-{{ mg_id }} {
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .mg-grid-{{ mg_id }} {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }

    {% if section.settings.grid_height_mode == 'same' %}
      .mg-grid-{{ mg_id }} .mg-item-{{ mg_id }} {
        height: {{ section.settings.grid_item_height | times: 0.7 }}px;
      }
    {% endif %}
  }
{% endstyle %}

<div class="mg-section-{{ mg_id }}" id="MediaGallery-{{ mg_id }}">
  <div class="mg-container-{{ mg_id }}">
    {% if section.blocks.size == 0 %}
      <div class="mg-empty-{{ mg_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="mg-empty-text-{{ mg_id }}">
          Add images or videos to your gallery using the blocks below
        </div>
      </div>
    {% else %}
      {% if section.settings.layout_type == 'grid' %}
        {%- liquid
          assign items_per_row = section.settings.columns_desktop
          assign rows_limit = section.settings.rows_before_show_more
          assign visible_count = items_per_row | times: rows_limit
        -%}

        <div class="mg-grid-{{ mg_id }}">
          {% for block in section.blocks %}
            {%- liquid
              assign is_hidden = false
              if forloop.index > visible_count
                assign is_hidden = true
              endif
            -%}

            <div class="mg-item-{{ mg_id }}{% if is_hidden %} mg-hidden-{{ mg_id }}{% endif %}" {{ block.shopify_attributes }}>
              {% case block.type %}
                {% when 'image' %}
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | image_url: width: 1200 }}"
                      alt="{{ block.settings.image.alt | escape }}"
                      loading="lazy"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}

                {% when 'video' %}
                  {% if block.settings.video_file != blank %}
                    {{ block.settings.video_file | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
                  {% elsif block.settings.video_url != blank %}
                    <video autoplay muted loop playsinline>
                      <source src="{{ block.settings.video_url }}" type="video/mp4">
                    </video>
                  {% else %}
                    {{ 'image' | placeholder_svg_tag }}
                  {% endif %}
              {% endcase %}
            </div>
          {% endfor %}
        </div>

        {% if section.blocks.size > visible_count %}
          <div class="mg-show-more-{{ mg_id }}">
            <button class="mg-show-more-btn-{{ mg_id }}" data-mg-show-more>
              {{ section.settings.show_more_text }}
            </button>
          </div>
        {% endif %}

      {% else %}
        <div class="mg-slider-{{ mg_id }}">
          <div class="mg-slider-track-{{ mg_id }}">
            {% for block in section.blocks %}
              <div class="mg-item-{{ mg_id }}" {{ block.shopify_attributes }}>
                {% case block.type %}
                  {% when 'image' %}
                    {% if block.settings.image != blank %}
                      <img
                        src="{{ block.settings.image | image_url: width: 1200 }}"
                        alt="{{ block.settings.image.alt | escape }}"
                        loading="lazy"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                      >
                    {% else %}
                      {{ 'image' | placeholder_svg_tag }}
                    {% endif %}

                  {% when 'video' %}
                    {% if block.settings.video_file != blank %}
                      {{ block.settings.video_file | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
                    {% elsif block.settings.video_url != blank %}
                      <video autoplay muted loop playsinline>
                        <source src="{{ block.settings.video_url }}" type="video/mp4">
                      </video>
                    {% else %}
                      {{ 'image' | placeholder_svg_tag }}
                    {% endif %}
                {% endcase %}
              </div>
            {% endfor %}
          </div>

          {% if section.blocks.size > 1 %}
            <button class="mg-slider-nav-{{ mg_id }} mg-slider-nav-{{ mg_id }}--prev" data-mg-prev>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>
            <button class="mg-slider-nav-{{ mg_id }} mg-slider-nav-{{ mg_id }}--next" data-mg-next>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>

            <div class="mg-slider-dots-{{ mg_id }}">
              {% for block in section.blocks %}
                <button class="mg-slider-dot-{{ mg_id }}{% if forloop.first %} active{% endif %}" data-mg-dot="{{ forloop.index0 }}"></button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

<script>
  (function() {
    var section = document.getElementById('MediaGallery-{{ mg_id }}');
    if (!section) return;

    {% if section.settings.layout_type == 'grid' %}
      var showMoreBtn = section.querySelector('[data-mg-show-more]');
      if (showMoreBtn) {
        showMoreBtn.addEventListener('click', function() {
          var hidden = section.querySelectorAll('.mg-hidden-{{ mg_id }}');
          for (var i = 0; i < hidden.length; i++) {
            hidden[i].classList.remove('mg-hidden-{{ mg_id }}');
          }
          showMoreBtn.parentElement.style.display = 'none';
        });
      }
    {% else %}
      var track = section.querySelector('.mg-slider-track-{{ mg_id }}');
      var slides = section.querySelectorAll('.mg-item-{{ mg_id }}');
      var prevBtn = section.querySelector('[data-mg-prev]');
      var nextBtn = section.querySelector('[data-mg-next]');
      var dots = section.querySelectorAll('[data-mg-dot]');
      var current = 0;
      var total = slides.length;

      function goTo(index) {
        current = index;
        if (track) track.style.transform = 'translateX(-' + (current * 100) + '%)';
        for (var i = 0; i < dots.length; i++) {
          dots[i].classList.toggle('active', i === current);
        }
      }

      if (prevBtn) prevBtn.addEventListener('click', function() {
        goTo(current === 0 ? total - 1 : current - 1);
      });
      if (nextBtn) nextBtn.addEventListener('click', function() {
        goTo(current === total - 1 ? 0 : current + 1);
      });
      for (var d = 0; d < dots.length; d++) {
        dots[d].addEventListener('click', function() {
          goTo(parseInt(this.getAttribute('data-mg-dot')));
        });
      }
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Media Gallery",
  "tag": "section",
  "class": "media-gallery-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout type",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "gap_size",
      "label": "Gap between items",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "5", "label": "Small" },
        { "value": "10", "label": "Medium" },
        { "value": "20", "label": "Large" }
      ],
      "default": "10"
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "select",
      "id": "grid_height_mode",
      "label": "Grid height mode",
      "options": [
        { "value": "same", "label": "Same height" },
        { "value": "auto", "label": "Auto height" }
      ],
      "default": "same"
    },
    {
      "type": "range",
      "id": "grid_item_height",
      "label": "Item height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "rows_before_show_more",
      "label": "Rows before show more",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "text",
      "id": "show_more_text",
      "label": "Show more button text",
      "default": "Show more"
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "range",
      "id": "slider_max_height",
      "label": "Max height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "media_bg_color",
      "label": "Media background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Slider nav background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Slider nav icon",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Slider dot active",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "dot_inactive_color",
      "label": "Slider dot inactive",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "media_border_radius",
      "label": "Media border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video_file",
          "label": "Shopify-hosted video"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "External video URL (MP4)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
