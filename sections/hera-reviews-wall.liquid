  var tabsDef = [
    {key:'all',label:'All ('+reviews.length+')'},
    {key:'player',label:'Players ('+reviews.filter(function(r){return r.c==='player'}).length+')'},
    {key:'parent',label:'Parents ('+reviews.filter(function(r){return r.c==='parent'}).length+')'},
    {key:'coach',label:'Coaches ('+reviews.filter(function(r){return r.c==='coach'}).length+')'}
  ];

  var tabsContainer = el.querySelector('[data-hr-tabs]');
  var track = el.querySelector('[data-hr-track]');
  var currentTab = 'all';

  function buildTabs(){
    tabsContainer.innerHTML = '';
    tabsDef.forEach(function(tab){
      var btn = document.createElement('button');
      btn.className = 'hr-wall__tab-'+sid + (tab.key===currentTab?' active':'');
      btn.textContent = tab.label;
      btn.setAttribute('data-hr-tab', tab.key);
      btn.addEventListener('click', function(){
        currentTab = tab.key;
        buildTabs();
        renderCards();
      });
      tabsContainer.appendChild(btn);
    });
  }

  function renderCards(){
    track.innerHTML = '';
    track.scrollLeft = 0;
    var filtered = currentTab==='all' ? reviews : reviews.filter(function(r){return r.c===currentTab});
    filtered.forEach(function(rv, idx){
      var prod = (typeof rv.p === 'number' && products[rv.p]) ? products[rv.p] : null;
      var initial = rv.n.charAt(0).toUpperCase();
      var bgColor = getColor(rv.n);

      var card = document.createElement('div');
      card.className = 'hr-wall__card-'+sid;

      var html = '<div class="hr-wall__stars-'+sid+'">'+starsSvg(rv.r)+'</div>';
      html += '<div class="hr-wall__text-'+sid+'" data-hr-review>'+escapeHtml(rv.x)+'</div>';
      html += '<button type="button" class="hr-wall__readmore-'+sid+'" data-hr-readmore>Read more</button>';
      html += '<div class="hr-wall__author-'+sid+'">';
      html += '<div class="hr-wall__initial-'+sid+'" style="background-color:'+bgColor+'">'+initial+'</div>';
      html += '<div class="hr-wall__author-info-'+sid+'">';
      html += '<span class="hr-wall__name-'+sid+'">'+escapeHtml(rv.n)+'</span>';
      html += '<span class="hr-wall__title-'+sid+'">'+escapeHtml(rv.t)+'</span>';
      html += '</div></div>';
      html += '<span class="hr-wall__badge-'+sid+'"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg> Verified Buyer</span>';

      if (prod) {
        html += '<a href="'+prod.u+'" class="hr-wall__product-'+sid+'">';
        if (prod.i) html += '<img src="'+prod.i+'" alt="'+escapeHtml(prod.t)+'" loading="lazy" width="48" height="48">';
        html += '<div class="hr-wall__product-info-'+sid+'">';
        html += '<span class="hr-wall__product-name-'+sid+'">'+escapeHtml(prod.t)+'</span>';
        html += '<span class="hr-wall__product-price-'+sid+'">'+formatMoney(prod.p);
        if (prod.c > 0) html += ' <span class="hr-wall__product-compare-'+sid+'">'+formatMoney(prod.c)+'</span>';
        html += '</span></div></a>';
      }

      card.innerHTML = html;
      track.appendChild(card);
    });
    initReadMore();
  }

  function escapeHtml(str){
    var d=document.createElement('div');
    d.appendChild(document.createTextNode(str));
    return d.innerHTML;
  }

  function initReadMore(){
    var btns = track.querySelectorAll('[data-hr-readmore]');
    btns.forEach(function(btn){
      var txt = btn.previousElementSibling;
      if (!txt) return;
      btn.addEventListener('click', function(){
        if(txt.classList.contains('expanded')){
          txt.classList.remove('expanded');
          btn.textContent = 'Read more';
        } else {
          txt.classList.add('expanded');
          btn.textContent = 'Read less';
        }
      });
    });
  }

  // Arrows
  var arrows = el.querySelectorAll('[data-hr-arrow]');
  arrows.forEach(function(arrow){
    arrow.addEventListener('click', function(){
      var dir = arrow.getAttribute('data-hr-arrow');
      var scrollAmt = 340;
      track.scrollBy({left: dir==='prev' ? -scrollAmt : scrollAmt, behavior:'smooth'});
    });
  });

  buildTabs();
  renderCards();
})();
</script>

